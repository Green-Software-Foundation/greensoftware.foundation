---
import { ArticleCarousel as ArticleCarouselReact } from "@/components/react/article-carousel";
import type { Article } from "@/components/react/article-carousel";

interface Props {
  /** Section heading */
  heading?: string;
  /** Body text under heading */
  body?: string;
  /** Array of article items */
  articles?: Article[];
  /** Background class */
  bgClass?: string;
  /** Whether to show organisation logos/names on cards (default true) */
  showOrganizations?: boolean;
  /** CTA link text */
  ctaText?: string;
  /** CTA link href */
  ctaHref?: string;
  /** Section ID for anchor links */
  id?: string;
}

const {
  heading,
  body,
  articles = [],
  bgClass = "bg-accent-lightest-2",
  showOrganizations = true,
  ctaText,
  ctaHref,
  id,
} = Astro.props;
---

<section id={id} class={`py-12 md:py-16 lg:py-20 ${bgClass}`}>
  <div class="container">
    <ArticleCarouselReact
      client:visible
      heading={heading}
      body={body}
      articles={articles}
      showOrganizations={showOrganizations}
      ctaText={ctaText}
      ctaHref={ctaHref}
    />
  </div>
</section>
