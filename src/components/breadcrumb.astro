---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  bgClass?: string;
}

const { items, bgClass = "bg-accent-lightest-2" } = Astro.props;
---

<nav aria-label="Breadcrumb" class={`pt-4 ${bgClass}`}>
  <div class="container">
    <ol class="flex items-center gap-1.5 text-sm text-primary-dark/70">
      {items.map((item, i) => (
        <>
          {i > 0 && <li aria-hidden="true" class="text-primary-dark/40">/</li>}
          <li>
            {item.href ? (
              <a href={item.href} class="hover:text-primary hover:underline flex items-center gap-1">
                {i === 0 && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
                )}
                {item.label}
              </a>
            ) : (
              <span class="font-medium text-primary-dark">{item.label}</span>
            )}
          </li>
        </>
      ))}
    </ol>
  </div>
</nav>
