---
import { Button } from "@/components/ui/button";
import Image from "@/components/image.astro";

interface Props {
  /** Main heading text. Wrap words in *asterisks* for accent color */
  heading?: string;
  /** Body text */
  body?: string;
  /** HTML body (rendered with set:html, used instead of body when provided) */
  bodyHtml?: string;
  /** CTA button text */
  ctaText?: string;
  /** CTA button link */
  ctaHref?: string;
  /** Illustration image source (shown on the left) */
  imageSrc?: string;
  /** Image alt text */
  imageAlt?: string;
  /** Background class */
  bgClass?: string;
  /** Visual variant: "light" (default, green card) or "dark" (dark teal card with white text) */
  variant?: "light" | "dark";
}

const {
  heading = "",
  body = "",
  bodyHtml,
  ctaText = "",
  ctaHref = "#",
  imageSrc = "/assets/ready.svg",
  imageAlt = "",
  bgClass = "bg-accent-lightest-2",
  variant = "light",
} = Astro.props;

const isDark = variant === "dark";

const headingParts = heading.split(/(\*[^*]+\*)/g).filter(Boolean).map(part => {
  if (part.startsWith("*") && part.endsWith("*")) {
    return { text: part.slice(1, -1), accent: true };
  }
  return { text: part, accent: false };
});
const hasAccentSyntax = headingParts.some(p => p.accent);
---

<section class={`py-12 md:py-18 lg:py-20 ${bgClass}`}>
  <div class="container">
    <div
      class:list={[
        "grid grid-cols-1 items-center justify-center gap-x-20 gap-y-12 rounded-2xl p-8 md:gap-y-16 md:p-12 lg:grid-cols-2 lg:justify-end lg:px-20",
        isDark ? "bg-primary-darker" : "bg-accent-lighter",
      ]}
    >
      {imageSrc && (
        <div class="hidden lg:flex lg:justify-center">
          <Image src={imageSrc} alt={imageAlt} class="object-cover" sizes="(min-width: 1024px) 50vw, 0px" />
        </div>
      )}
      <div>
        <h2 class:list={["mb-3 text-2xl font-bold md:mb-4 md:text-3xl lg:text-4xl", isDark && "text-white"]}>
          {hasAccentSyntax
            ? headingParts.map(part =>
                part.accent
                  ? <span class={isDark ? "text-accent" : "text-primary"}>{part.text}</span>
                  : <span class={isDark ? "text-white" : "text-primary-darker"}>{part.text}</span>
              )
            : heading
          }
        </h2>
        {bodyHtml ? (
          <div set:html={bodyHtml} class:list={["text-sm lg:text-base", isDark ? "text-white/80" : ""]} />
        ) : body ? (
          <p class:list={["text-sm lg:text-base", isDark ? "text-white/80" : ""]}>{body}</p>
        ) : null}
        {ctaText && (
          <div class="mt-6 flex flex-wrap gap-4 md:mt-8">
            <a href={ctaHref}>
              <Button variant={isDark ? "primary-invert" : "primary"}>{ctaText}</Button>
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
