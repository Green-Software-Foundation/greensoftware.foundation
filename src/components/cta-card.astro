---
import { Button } from "@/components/ui/button";
import Image from "@/components/image.astro";

interface Props {
  /** Main heading text. Wrap words in *asterisks* for accent colour */
  heading?: string;
  /** Body text */
  body?: string;
  /** HTML body (rendered with set:html, used instead of body when provided) */
  bodyHtml?: string;
  /** CTA button text */
  ctaText?: string;
  /** CTA button link */
  ctaHref?: string;
  /** Illustration image source (shown on the left) */
  imageSrc?: string;
  /** Image alt text */
  imageAlt?: string;
  /** Background class */
  bgClass?: string;
}

const {
  heading = "",
  body = "",
  bodyHtml,
  ctaText = "",
  ctaHref = "#",
  imageSrc = "/assets/ready.svg",
  imageAlt = "",
  bgClass = "bg-accent-lightest-2",
} = Astro.props;

const headingParts = heading.split(/(\*[^*]+\*)/g).filter(Boolean).map(part => {
  if (part.startsWith("*") && part.endsWith("*")) {
    return { text: part.slice(1, -1), accent: true };
  }
  return { text: part, accent: false };
});
const hasAccentSyntax = headingParts.some(p => p.accent);
---

<section class={`py-12 md:py-18 lg:py-20 ${bgClass}`}>
  <div class="container">
    <div
      class="grid grid-cols-1 items-center justify-center gap-x-20 gap-y-12 rounded-2xl bg-accent-lighter p-8 md:gap-y-16 md:p-12 lg:grid-cols-2 lg:justify-end lg:px-20"
    >
      {imageSrc && (
        <div class="hidden lg:flex lg:justify-center">
          <Image src={imageSrc} alt={imageAlt} class="object-cover" sizes="(min-width: 1024px) 50vw, 0px" />
        </div>
      )}
      <div>
        <h2 class="mb-3 text-2xl font-bold md:mb-4 md:text-3xl lg:text-4xl">
          {hasAccentSyntax
            ? headingParts.map(part =>
                part.accent
                  ? <span class="text-primary">{part.text}</span>
                  : <span class="text-primary-darker">{part.text}</span>
              )
            : heading
          }
        </h2>
        {bodyHtml ? (
          <div set:html={bodyHtml} class="text-sm lg:text-base" />
        ) : body ? (
          <p class="text-sm lg:text-base">{body}</p>
        ) : null}
        {ctaText && (
          <div class="mt-6 flex flex-wrap gap-4 md:mt-8">
            <a href={ctaHref}>
              <Button>{ctaText}</Button>
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
