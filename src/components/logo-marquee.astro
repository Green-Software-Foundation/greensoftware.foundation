---
import Image from "@/components/image.astro";

interface Logo {
  name: string;
  logo: string;
  website: string;
}

interface Props {
  /** Heading text above the marquee */
  heading?: string;
  /** Array of logo data. If not provided, loads from members.json */
  logos?: Logo[];
  /** Background class for the section */
  bgClass?: string;
  /** Background class for the gradient fade edges */
  fadeBgClass?: string;
  /** Whether logos should be grayscale by default */
  grayscale?: boolean;
  /** Link to the full member directory */
  directoryHref?: string;
  /** Text for the directory link */
  directoryText?: string;
}

const {
  heading = "ISO-accredited and endorsed by leading technology organizations",
  logos: propLogos,
  bgClass = "bg-white",
  fadeBgClass,
  grayscale = false,
  directoryHref = "https://directory.greensoftware.foundation/members/",
  directoryText = "View all members",
} = Astro.props;

const logos: Logo[] = propLogos || (await import("../data/members.json")).default
  .filter((m: any) => m.active && m.logo && !m.hideLogo)
  .sort((a: any, b: any) => {
    // Steering members first, then General — alphabetical within each tier
    if (a.membershipLevel !== b.membershipLevel) {
      return a.membershipLevel === "Steering" ? -1 : 1;
    }
    return a.companyName.localeCompare(b.companyName);
  })
  .map((m: any) => ({ name: m.companyName, logo: `/assets/${m.logo}`, website: m.companyWebsite }));
const marqueeDuration = Math.max(logos.length * 3.75, 38);

// Determine the gradient "from" color based on background
const fadeFrom = fadeBgClass || (bgClass.includes("accent-lightest-2") ? "from-accent-lightest-2" : "from-white");
---

<section
  class={`py-6 md:py-8 ${bgClass}`}
  style={`--marquee-duration: ${marqueeDuration}s`}
  role="region"
  aria-roledescription="carousel"
  aria-label="Member organizations"
>
  <div class="relative container overflow-hidden">
    <!-- Heading row with controls — pause button in DOM before scrolling content for keyboard order -->
    <div class="relative mb-4 flex items-center justify-center md:mb-6">
      <p class="text-center text-sm font-medium text-gray-darker">
        {heading}
      </p>
      <div class="absolute right-0 flex shrink-0 items-center gap-3">
        <a
          href={directoryHref}
          class="hidden text-xs font-semibold text-primary underline-offset-2 hover:underline sm:inline"
        >
          {directoryText} &rarr;
        </a>
        <button
          type="button"
          class="marquee-pause-btn flex h-7 w-7 items-center justify-center rounded-full border border-gray text-gray-darker transition-colors hover:border-primary hover:text-primary focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
          aria-label="Pause logo carousel"
        >
          <svg class="pause-icon h-3 w-3" aria-hidden="true" fill="currentColor" viewBox="0 0 24 24">
            <rect x="6" y="4" width="4" height="16" />
            <rect x="14" y="4" width="4" height="16" />
          </svg>
          <svg class="play-icon hidden h-3 w-3" aria-hidden="true" fill="currentColor" viewBox="0 0 24 24">
            <polygon points="6,4 20,12 6,20" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Live region for announcing pause/play state changes -->
    <div class="sr-only" aria-live="polite" aria-atomic="true" data-marquee-status></div>

    <div class="marquee-track group relative flex items-center overflow-hidden">
      <div class={`absolute top-0 bottom-0 left-0 z-10 w-20 bg-gradient-to-r ${fadeFrom} to-transparent`}></div>
      <div class={`absolute top-0 right-0 bottom-0 z-10 w-20 bg-gradient-to-l ${fadeFrom} to-transparent`}></div>

      <!-- Primary logo set -->
      <div class="flex shrink-0 animate-marquee items-center gap-12" role="group" aria-label="Member organization logos">
        {logos.map((logo) => (
          <a
            href={`//${logo.website.replace(/^https?:\/\//, '').replace(/^www\./, '')}`}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              "mx-6 flex h-10 w-32 shrink-0 cursor-pointer items-center justify-center overflow-hidden md:h-12 md:w-40",
              grayscale && "grayscale opacity-60 transition-all duration-300 hover:grayscale-0 hover:opacity-100",
            ]}
            aria-label={logo.name}
          >
            <Image
              class="max-h-full max-w-full object-contain"
              src={logo.logo}
              alt=""
              sizes="160px"
              widths={[160, 320]}
              width={160}
              height={48}
            />
          </a>
        ))}
      </div>

      <!-- Duplicate for seamless loop — hidden from assistive technology -->
      <div class="flex shrink-0 animate-marquee items-center gap-12" aria-hidden="true">
        {logos.map((logo) => (
          <a
            href={`//${logo.website.replace(/^https?:\/\//, '').replace(/^www\./, '')}`}
            target="_blank"
            rel="noopener noreferrer"
            tabindex="-1"
            class:list={[
              "mx-6 flex h-10 w-32 shrink-0 cursor-pointer items-center justify-center overflow-hidden md:h-12 md:w-40",
              grayscale && "grayscale opacity-60 transition-all duration-300 hover:grayscale-0 hover:opacity-100",
            ]}
          >
            <Image
              class="max-h-full max-w-full object-contain"
              src={logo.logo}
              alt=""
              sizes="160px"
              widths={[160, 320]}
              width={160}
              height={48}
            />
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Pause on hover */
  .marquee-track:hover .animate-marquee {
    animation-play-state: paused;
  }

  /* Paused state toggled by JS */
  .marquee-track.is-paused .animate-marquee {
    animation-play-state: paused;
  }

  /* Respect reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    .animate-marquee {
      animation: none;
    }
  }
</style>

<script>
  document.querySelectorAll('.marquee-pause-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const section = btn.closest('section');
      if (!section) return;

      const track = section.querySelector('.marquee-track');
      const pauseIcon = btn.querySelector('.pause-icon');
      const playIcon = btn.querySelector('.play-icon');
      const status = section.querySelector('[data-marquee-status]');
      if (!track || !pauseIcon || !playIcon) return;

      const isPaused = track.classList.toggle('is-paused');

      pauseIcon.classList.toggle('hidden', isPaused);
      playIcon.classList.toggle('hidden', !isPaused);

      btn.setAttribute('aria-label', isPaused ? 'Play logo carousel' : 'Pause logo carousel');

      if (status) {
        status.textContent = isPaused ? 'Logo carousel paused' : 'Logo carousel playing';
      }
    });
  });
</script>
