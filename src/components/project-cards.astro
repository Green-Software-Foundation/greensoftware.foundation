---
import { Button } from "@/components/ui/button";
import Image from "@/components/image.astro";

interface ProjectOrg {
  /** Organisation name */
  name: string;
  /** Path to organisation logo */
  logoSrc: string;
}

interface Project {
  /** Problem statement / card title */
  title: string;
  /** Short description of the solution */
  description: string;
  /** Organisations involved */
  orgs?: ProjectOrg[];
  /** Link to the full story */
  href?: string;
  /** CTA text */
  cta?: string;
}

interface Props {
  /** Heading text. Wrap words in *asterisks* for accent colour */
  heading?: string;
  /** Body text under heading */
  body?: string;
  /** Array of project cards */
  projects?: Project[];
  /** Footer CTA text */
  footerCtaText?: string;
  /** Footer CTA href */
  footerCtaHref?: string;
  /** Background class */
  bgClass?: string;
}

const {
  heading = "",
  body,
  projects = [],
  footerCtaText,
  footerCtaHref = "#",
  bgClass = "bg-accent-lightest-2",
} = Astro.props;

// Split heading into plain and accent segments
const headingParts = heading.split(/(\*[^*]+\*)/g).filter(Boolean).map(part => {
  if (part.startsWith("*") && part.endsWith("*")) {
    return { text: part.slice(1, -1), accent: true };
  }
  return { text: part, accent: false };
});
---

<section class={`py-16 md:py-20 ${bgClass}`}>
  <div class="container">
    <div class="mx-auto max-w-5xl text-center">
      <h2 class="text-2xl font-semibold md:text-3xl lg:text-4xl">
        {headingParts.map(part =>
          part.accent
            ? <span class="font-bold text-primary">{part.text}</span>
            : part.text
        )}
      </h2>
      {body && (
        <p class="mt-4 text-lg leading-relaxed md:text-xl">{body}</p>
      )}
    </div>

    <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
      {projects.map((project) => {
        const orgCount = project.orgs?.length ?? 0;
        const marqueeDuration = Math.max(orgCount * 3, 12);
        return (
          <a
            href={project.href || "#"}
            class="project-card group flex flex-col overflow-hidden rounded-xl bg-primary-darker transition-shadow hover:shadow-lg"
            style={`--marquee-duration: ${marqueeDuration}s`}
          >
            <div class="flex flex-1 flex-col justify-between p-6 md:p-8">
              <div>
                <h3 class="text-lg font-bold leading-tight text-white md:text-xl">{project.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-white/70">{project.description}</p>
              </div>
              <span class="mt-5 inline-flex items-center text-sm font-bold text-accent group-hover:underline">
                {project.cta || "Read the story →"}
              </span>
            </div>

            {orgCount > 0 && (
              <div class="overflow-hidden border-t border-white/10 px-6 py-4 md:px-8">
                <p class="mb-2 text-[10px] uppercase tracking-wider text-white/40">Members who Contributed</p>
                <div class="marquee-track relative flex items-center overflow-hidden">
                  <div class="absolute top-0 bottom-0 left-0 z-10 w-6 bg-gradient-to-r from-primary-darker to-transparent" />
                  <div class="absolute top-0 right-0 bottom-0 z-10 w-6 bg-gradient-to-l from-primary-darker to-transparent" />
                  {[0, 1].map(() => (
                    <div class="flex shrink-0 animate-marquee items-center gap-6 pr-12">
                      {project.orgs!.map((org) => (
                        <Image
                          src={org.logoSrc}
                          alt={org.name}
                          class="h-5 w-auto max-w-[72px] shrink-0 object-contain brightness-0 invert opacity-50"
                          sizes="72px"
                          widths={[72, 144]}
                          height={20}
                        />
                      ))}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </a>
        );
      })}
    </div>

    {footerCtaText && (
      <div class="mt-10 text-center">
        <a href={footerCtaHref}>
          <Button variant="primary" class="px-8 py-3 text-base">{footerCtaText}</Button>
        </a>
      </div>
    )}
  </div>
</section>

<style>
  .project-card .marquee-track:hover .animate-marquee {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card .animate-marquee {
      animation: none;
    }
  }
</style>
