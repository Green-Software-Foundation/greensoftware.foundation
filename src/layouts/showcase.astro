---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  article?: {
    publishedTime?: string;
    authors?: string[];
  };
}

const {
  title = "Green Software Foundation",
  description = "Building a trusted ecosystem of people, standards, tooling, and best practices for green software.",
  ogImage,
  ogType = "website",
  noindex = false,
  article,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://greensoftware.foundation");
const defaultOgImage = "/assets/og-image-default.png";
const ogImageURL = new URL(ogImage || defaultOgImage, "https://greensoftware.foundation").href;
---

<html lang="en">
  <head>
    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-593HJXNS18"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-593HJXNS18');
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/assets/favicon.png" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Green Software Foundation" />
    <meta property="og:image" content={ogImageURL} />
    {article?.publishedTime && <meta property="article:published_time" content={article.publishedTime} />}
    {article?.authors?.map((author) => <meta property="article:author" content={author} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:site" content="@gsfcommunity" />
    <meta name="twitter:image" content={ogImageURL} />
    <slot name="head" />
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
