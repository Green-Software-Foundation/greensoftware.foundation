---
import { getCollection } from "astro:content";
import Layout from "@/layouts/showcase.astro";
import Navbar from "@/components/navbar.astro";
import Footer from "@/components/footer.astro";
import Breadcrumb from "@/components/breadcrumb.astro";
import TextBlock from "@/components/text-block.astro";
import LogoMarquee from "@/components/logo-marquee.astro";
import { Button } from "@/components/ui/button";
import { navItems } from "@/lib/nav-items";
import membersData from "@/data/members.json";

const academics = (await getCollection("academics")).filter(
  (a) => a.data.published !== false
);

// Academic institution logos from the GSF member directory
const academicMemberLogos = (membersData as any[])
  .filter((m) => m.active && m.organisationType === "Academia" && m.logo && !m.hideLogo)
  .map((m) => ({ name: m.companyName, logo: `/assets/${m.logo}`, website: m.companyWebsite || "https://greensoftware.foundation/" }));

// Fall back to profile-sourced logos if no academic members exist in the directory (e.g. dev without NOTION_API_KEY)
const profileLogos = academics.flatMap((a) => {
  const logos = a.data.institutionLogos;
  if (logos && logos.length > 0) {
    return logos.map((inst) => ({
      name: inst.name,
      logo: inst.logo ?? "/assets/academics/institution-placeholder.svg",
      website: inst.url ?? a.data.institutionUrl ?? "https://greensoftware.foundation/",
    }));
  }
  return [{
    name: a.data.institution,
    logo: a.data.institutionLogo ?? "/assets/academics/institution-placeholder.svg",
    website: a.data.institutionUrl ?? "https://greensoftware.foundation/",
  }];
});

const institutionLogos = academicMemberLogos.length > 0 ? academicMemberLogos : profileLogos;
---

<Layout
  title="Academic Members — Green Software Foundation"
  description="Distinguished academics advancing green software research and innovation in collaboration with the Green Software Foundation."
>
  <Navbar
    logoSrc="/assets/gsf-logo-full.svg"
    logoAlt="Green Software Foundation"
    logoHref="/"
    topBar="none"
    showSearch
    navItems={navItems}
  />

  <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Academics" }]} />

  <!-- Hero -->
  <section class="bg-primary-darker text-white py-16 md:py-20">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <p class="text-accent font-bold text-sm uppercase tracking-widest mb-4">
          Academic Partnerships
        </p>
        <h1 class="font-extrabold text-4xl md:text-5xl lg:text-6xl leading-tight mb-6">
          Academic <span class="text-accent">Members</span>
        </h1>
        <p class="text-lg md:text-xl text-white/80 leading-relaxed max-w-3xl">
          Distinguished academics advancing research in green software, energy-efficient AI, and sustainable computing. These researchers bring academic rigor and innovation to GSF's standards and initiatives.
        </p>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <TextBlock
    heading="Building Bridges Between *Academia and Industry*"
    body="The Green Software Foundation collaborates with leading academic institutions and researchers to advance the science of green software. Our academic partners contribute cutting-edge research, validation of our standards, and expertise in emerging areas like energy-efficient AI and neuromorphic computing."
    bgClass="bg-accent-lightest-2"
  />

  <!-- Academic institution logo bar -->
  {institutionLogos.length > 0 && (
    <LogoMarquee
      heading="Partnering with leading research institutions"
      logos={institutionLogos}
      bgClass="bg-white"
      fadeBgClass="from-white"
      directoryHref="/academics/"
      directoryText="View all academic members"
    />
  )}

  <!-- Academics Grid -->
  {academics.length > 0 ? (
    <section class="py-12 md:py-16 lg:py-20 bg-white">
      <div class="container">
        <div class="mb-8 md:mb-10 text-center">
          <h2 class="text-2xl font-semibold md:text-3xl lg:text-4xl">
            Meet Our <span class="font-bold text-primary">Academic Members</span>
          </h2>
        </div>
        <div class="grid gap-6 sm:grid-cols-2">
          {academics.map((academic) => {
            const logos = academic.data.institutionLogos && academic.data.institutionLogos.length > 0
              ? academic.data.institutionLogos
              : [{ name: academic.data.institution, logo: academic.data.institutionLogo ?? "/assets/academics/institution-placeholder.svg", url: academic.data.institutionUrl }];
            return (
              <div class="flex flex-col rounded-xl border bg-white shadow-sm overflow-hidden">
                <!-- Institution header -->
                <div class="bg-accent-lightest-2 px-6 py-5 flex flex-col items-center gap-4 border-b border-border">
                  <div class={`flex items-center justify-center gap-4 ${logos.length > 1 ? "w-full" : ""}`}>
                    {logos.map((inst) => (
                      <a
                        href={inst.url ?? academic.data.institutionUrl ?? "#"}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex-1 flex items-center justify-center"
                        title={inst.name}
                      >
                        <div class={`rounded-lg bg-white border border-border flex items-center justify-center overflow-hidden shadow-sm ${logos.length > 1 ? "w-full h-16 px-3 py-2" : "w-20 h-20 p-2"}`}>
                          <img
                            src={inst.logo ?? "/assets/academics/institution-placeholder.svg"}
                            alt={`${inst.name} logo`}
                            class="max-w-full max-h-full object-contain"
                          />
                        </div>
                      </a>
                    ))}
                  </div>
                  <p class="text-center text-sm font-semibold text-primary-dark leading-snug">
                    {logos.map((inst, i) => (
                      <>
                        <a
                          href={inst.url ?? academic.data.institutionUrl ?? "#"}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="hover:text-primary hover:underline transition-colors"
                        >{inst.name}</a>{i < logos.length - 1 ? " & " : ""}
                      </>
                    ))}
                  </p>
                </div>
                <!-- Profile body -->
                <div class="flex flex-col flex-grow p-6">
                  <p class="text-xs font-bold uppercase tracking-widest text-accent mb-1">Academic Member</p>
                  <h3 class="text-xl font-extrabold text-primary leading-snug mb-1">
                    {academic.data.name}
                  </h3>
                  <p class="text-sm text-gray-darker mb-4 leading-snug">{academic.data.title}</p>
                  <p class="text-sm text-gray-darker leading-relaxed flex-grow">
                    {academic.data.summary}
                  </p>
                  <div class="mt-6">
                    <a href={`/academics/${academic.id}/`}>
                      <Button variant="primary" className="w-full">View Profile →</Button>
                    </a>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  ) : (
    <section class="py-12 md:py-16 bg-white">
      <div class="container">
        <div class="text-center py-12">
          <p class="text-gray-600 text-lg">No published academic profiles yet.</p>
        </div>
      </div>
    </section>
  )}

  <Footer />
</Layout>
