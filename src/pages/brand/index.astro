---
import Layout from "@/layouts/showcase.astro";
import { navItems } from "@/lib/nav-items";

import Navbar from "@/components/navbar.astro";
import Hero from "@/components/hero.astro";
import TextBlock from "@/components/text-block.astro";
import FeatureGrid from "@/components/feature-grid.astro";
import CTABanner from "@/components/cta-banner.astro";
import Footer from "@/components/footer.astro";
---

<Layout
  title="Brand & Assets — Green Software Foundation"
  description="Download GSF logos, icons, illustrations, and presentation templates. Brand guidelines, colour palette, and resources for members and meetup organisers."
>
  <Navbar
    logoSrc="/assets/gsf-logo-full.svg"
    logoAlt="Green Software Foundation"
    logoHref="/"
    topBar="none"
    showSearch
    navItems={navItems}
    ctaText="Discuss your challenges"
    ctaHref="/membership/"
  />

  <!-- Hero -->
  <Hero
    heading="Brand"
    headingAccent="& Assets"
    body="Everything you need to represent the Green Software Foundation consistently across digital and print media. Download logos, icons, illustrations, and presentation templates."
    ctas={[
      { text: "Download brand guidelines", variant: "primary", href: "https://drive.google.com/file/d/1aqa1Idj-2K1r09ezCMwN38kjWTegOSSd/view" },
      { text: "View trademark policy", variant: "outline", href: "/policy/trademark" },
    ]}
    imageSrc="/assets/hero-illustration.svg"
    imageAlt="Brand assets illustration"
    bgClass="bg-accent-lightest-2"
  />

  <!-- Brand Guidelines -->
  <TextBlock
    heading="Using our *brand*"
    body="Please review our Brand Guidelines and Trademark Policy before using GSF branding in any materials. These resources will help you communicate our shared mission with consistency and clarity."
    compact
  />

  <!-- Colour Palette -->
  <section class="bg-white py-16 md:py-20">
    <div class="container">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-center text-2xl font-semibold md:text-3xl lg:text-4xl">
          Colour <span class="font-bold text-primary">Palette</span>
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-center text-lg text-primary-dark/80">
          A quick overview of our core palettes. These are just the highlights — the full brand guidelines cover colour ratios, usage rules, logo placement, and much more.
        </p>

        <!-- Primary Palette -->
        <h3 class="mt-12 text-lg font-bold text-primary-dark">Primary (Teal)</h3>
        <div class="mt-4 grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-7">
          {[
            { name: "Darkest", hex: "#003834" },
            { name: "Dark", hex: "#00544F" },
            { name: "Primary", hex: "#006D68" },
            { name: "Medium", hex: "#338A86" },
            { name: "Light", hex: "#6FAFAC" },
            { name: "Lighter", hex: "#AFD3D0" },
            { name: "Lightest", hex: "#D9E7E7" },
          ].map(({ name, hex }) => (
            <div class="text-center">
              <div class="mx-auto h-16 w-full rounded-lg border border-border" style={`background-color: ${hex}`} />
              <p class="mt-2 text-xs font-semibold text-primary-dark">{name}</p>
              <p class="text-xs text-gray-darker">{hex}</p>
            </div>
          ))}
        </div>

        <!-- Accent Palette -->
        <h3 class="mt-10 text-lg font-bold text-primary-dark">Accent (Green)</h3>
        <div class="mt-4 grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-7">
          {[
            { name: "Darkest", hex: "#849E2A" },
            { name: "Dark", hex: "#99B439" },
            { name: "Accent", hex: "#AECC53" },
            { name: "Medium", hex: "#BED675" },
            { name: "Light", hex: "#CEE098" },
            { name: "Lighter", hex: "#EBF2D4" },
            { name: "Lightest", hex: "#F2F6E9" },
          ].map(({ name, hex }) => (
            <div class="text-center">
              <div class="mx-auto h-16 w-full rounded-lg border border-border" style={`background-color: ${hex}`} />
              <p class="mt-2 text-xs font-semibold text-primary-dark">{name}</p>
              <p class="text-xs text-gray-darker">{hex}</p>
            </div>
          ))}
        </div>

        <!-- Grey Palette -->
        <h3 class="mt-10 text-lg font-bold text-primary-dark">Grey</h3>
        <div class="mt-4 grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-7">
          {[
            { name: "Black", hex: "#000000" },
            { name: "Darkest", hex: "#1E1E1E" },
            { name: "Dark", hex: "#3C3C3C" },
            { name: "Medium", hex: "#595959" },
            { name: "Grey", hex: "#808080" },
            { name: "Light", hex: "#A9A9A9" },
            { name: "Lightest", hex: "#C3C3C3" },
          ].map(({ name, hex }) => (
            <div class="text-center">
              <div class="mx-auto h-16 w-full rounded-lg border border-border" style={`background-color: ${hex}`} />
              <p class="mt-2 text-xs font-semibold text-primary-dark">{name}</p>
              <p class="text-xs text-gray-darker">{hex}</p>
            </div>
          ))}
        </div>

        <!-- Accent Highlights -->
        <h3 class="mt-10 text-lg font-bold text-primary-dark">Accent Highlights</h3>
        <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-2 md:w-2/7">
          {[
            { name: "Orange", hex: "#D87814" },
            { name: "Cyan", hex: "#00E7FF" },
          ].map(({ name, hex }) => (
            <div class="text-center">
              <div class="mx-auto h-16 w-full rounded-lg border border-border" style={`background-color: ${hex}`} />
              <p class="mt-2 text-xs font-semibold text-primary-dark">{name}</p>
              <p class="text-xs text-gray-darker">{hex}</p>
            </div>
          ))}
        </div>

        <div class="mt-12 rounded-xl border border-primary/20 bg-primary-lightest-1 p-6 text-center">
          <p class="text-base font-semibold text-primary-dark">
            This is just a snapshot of our brand palette.
          </p>
          <p class="mt-2 text-sm text-primary-dark/80">
            The full brand guidelines include colour usage ratios, logo placement rules, correct and incorrect usage examples, background guidelines, and much more. Please read them before using GSF branding.
          </p>
          <a
            href="https://drive.google.com/file/d/1aqa1Idj-2K1r09ezCMwN38kjWTegOSSd/view"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center rounded-lg bg-primary px-6 py-3 text-sm font-bold text-white transition-colors hover:bg-primary-dark"
          >
            Read the full brand guidelines →
          </a>
        </div>

        <!-- Font -->
        <h3 class="mt-10 text-lg font-bold text-primary-dark">Typography</h3>
        <div class="mt-4 rounded-xl border border-border bg-accent-lightest-2 p-6">
          <p class="text-3xl font-extrabold text-primary-dark">Nunito Sans</p>
          <p class="mt-2 text-base text-gray-darker">
            Our primary typeface. Used across all digital and print materials.
          </p>
          <div class="mt-4 flex flex-wrap gap-6 text-sm text-primary-dark">
            <span class="font-extralight">ExtraLight (200)</span>
            <span class="font-light">Light (300)</span>
            <span>Regular (400)</span>
            <span class="font-semibold">Semibold (600)</span>
            <span class="font-bold">Bold (700)</span>
            <span class="font-extrabold">ExtraBold (800)</span>
            <span class="font-black">Black (900)</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Logo Preview -->
  <section class="bg-accent-lightest-2 py-16 md:py-20">
    <div class="container">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-center text-2xl font-semibold md:text-3xl lg:text-4xl">
          Our <span class="font-bold text-primary">Logos</span>
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-center text-lg text-primary-dark/80">
          Use the approved logo variants below. Always download from the official source — do not recreate or modify.
        </p>

        <div class="mt-10 grid gap-6 md:grid-cols-3">
          <!-- Full Logo -->
          <div class="flex flex-col items-center rounded-xl border border-border bg-white p-8">
            <div class="flex h-24 items-center">
              <img src="/assets/gsf-logo-full.svg" alt="GSF Full Logo" class="h-14" />
            </div>
            <p class="mt-4 text-sm font-semibold text-primary-dark">Full Logo</p>
            <p class="text-xs text-gray-darker">Primary use</p>
          </div>

          <!-- Vertical Logo -->
          <div class="flex flex-col items-center rounded-xl border border-border bg-white p-8">
            <div class="flex h-24 items-center">
              <img src="/assets/gsf-logo-vertical.svg" alt="GSF Vertical Logo" class="h-20" />
            </div>
            <p class="mt-4 text-sm font-semibold text-primary-dark">Vertical Logo</p>
            <p class="text-xs text-gray-darker">Stacked layout</p>
          </div>

          <!-- Icon -->
          <div class="flex flex-col items-center rounded-xl border border-border bg-white p-8">
            <div class="flex h-24 items-center">
              <img src="/assets/gsf-logo.svg" alt="GSF Icon" class="h-16" />
            </div>
            <p class="mt-4 text-sm font-semibold text-primary-dark">Icon</p>
            <p class="text-xs text-gray-darker">Favicon, small spaces</p>
          </div>
        </div>

        <div class="mt-8 text-center">
          <a
            href="https://drive.google.com/drive/folders/13fMib7sl6mHdq0W_tZKE-N3kAYxO1LqP"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center rounded-lg bg-primary px-6 py-3 text-sm font-bold text-white transition-colors hover:bg-primary-dark"
          >
            Download all logos →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Asset Downloads -->
  <FeatureGrid
    heading="Download *Assets*"
    body="All brand assets are hosted on Google Drive. Click through to browse and download."
    variant="bordered"
    columns={3}
    features={[
      {
        icon: "/assets/shape-icon-1.svg",
        title: "Logos",
        description: "Full logo, vertical, icon, and monochrome variants in SVG and PNG formats.",
        linkText: "Download logos →",
        linkHref: "https://drive.google.com/drive/folders/13fMib7sl6mHdq0W_tZKE-N3kAYxO1LqP",
      },
      {
        icon: "/assets/shape-icon-2.svg",
        title: "Icons",
        description: "Project and programme icons used across GSF materials and microsites.",
        linkText: "Download icons →",
        linkHref: "https://drive.google.com/drive/folders/1BFMn9Pk1Fa9ukLmQj6I2JgdbC8ah8PB9",
      },
      {
        icon: "/assets/shape-icon-3.svg",
        title: "Illustrations",
        description: "Custom illustrations used across the website and marketing materials.",
        linkText: "Download illustrations →",
        linkHref: "https://drive.google.com/drive/folders/1Vh5fT1UJb5Csommb50_NioYlnSeMH8ep",
      },
      {
        icon: "/assets/standardized-icon.svg",
        title: "Presentation Templates",
        description: "Branded slide decks for member presentations, talks, and workshops.",
        linkText: "Download templates →",
        linkHref: "https://drive.google.com/drive/folders/11Ty2C4l4gVUMES9cLw0glrhD4EbvHDif",
      },
      {
        icon: "/assets/co2-icon.svg",
        title: "Our Work",
        description: "Assets for individual projects, specifications, and working groups.",
        linkText: "Download project assets →",
        linkHref: "https://drive.google.com/drive/folders/1jiAZjhZ7vvT73rNyxYEwM1dcjLhX-ys0",
      },
      {
        icon: "/assets/renewable-icon.svg",
        title: "All Brand Assets",
        description: "The complete brand asset library — everything in one place.",
        linkText: "Browse all assets →",
        linkHref: "https://drive.google.com/drive/folders/1F4mnbOAL1B88g5CZINPze-NzwZAch1DJ",
      },
    ]}
    bgClass="bg-white"
  />

  <!-- Canva Templates & Community Resources -->
  <section class="bg-accent-lightest-2 py-16 md:py-20">
    <div class="container">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-center text-2xl font-semibold md:text-3xl lg:text-4xl">
          Canva <span class="font-bold text-primary">Templates</span>
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-center text-lg text-primary-dark/80">
          Ready-to-use Canva templates for meetup organisers. Make a copy of the template before editing.
        </p>

        <div class="mt-10 grid gap-6 md:grid-cols-2">
          <!-- Meetup Templates -->
          <div class="rounded-xl border border-border bg-white p-6">
            <h3 class="text-lg font-bold text-primary-dark">Meetup Templates (1200x676 px)</h3>
            <ul class="mt-4 space-y-3">
              <li>
                <a href="https://www.canva.com/design/DAGpOpsoCNI/qM-4N4nN6_KVFEC0fFFiuA/edit" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-primary hover:underline">
                  Meetup kit →
                </a>
              </li>
              <li>
                <a href="https://www.canva.com/design/DAFd8CdF8FU/rbqpDiNx-dd38VzaDTDG2A/edit" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-primary hover:underline">
                  Meetup speakers →
                </a>
              </li>
              <li>
                <a href="https://www.canva.com/design/DAFd8eouZY0/tx0u7UgauUXsXdbDZo15Yw/edit" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-primary hover:underline">
                  Meetup event cover →
                </a>
              </li>
              <li>
                <a href="https://www.canva.com/design/DAFd8BweuWs/p1lN9HWPgNidoNjPVet2Sw/edit" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-primary hover:underline">
                  Meetup group cover (default) →
                </a>
              </li>
            </ul>
          </div>

          <!-- Social Templates -->
          <div class="rounded-xl border border-border bg-white p-6">
            <h3 class="text-lg font-bold text-primary-dark">Social Templates (1200x1200 px)</h3>
            <ul class="mt-4 space-y-3">
              <li>
                <a href="https://www.canva.com/design/DAFdR3buaRM/pJJGbB3Mg10nHo59_ll-NA/edit" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-primary hover:underline">
                  Speakers →
                </a>
              </li>
              <li>
                <a href="https://www.canva.com/design/DAFd8vPBnDI/a-rEAUbNAtQcnsIQEPazUQ/edit" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-primary hover:underline">
                  Event →
                </a>
              </li>
            </ul>

            <h3 class="mt-8 text-lg font-bold text-primary-dark">More Resources</h3>
            <ul class="mt-4 space-y-3">
              <li>
                <a href="https://drive.google.com/drive/folders/1QRJZTWPYFWrrzXSuYE14coFH_TZ4X1ve" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-primary hover:underline">
                  All meetup assets (Google Drive) →
                </a>
              </li>
              <li>
                <a href="https://drive.google.com/drive/folders/1sj9HAadY0lWj035K5DVSlNT2P6nvFJ3l" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-primary hover:underline">
                  Champions assets (Google Drive) →
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Official Description -->
  <section class="bg-white py-16 md:py-20">
    <div class="container">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-center text-2xl font-semibold md:text-3xl lg:text-4xl">
          Official <span class="font-bold text-primary">Description</span>
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-center text-lg text-primary-dark/80">
          Please use this approved description when referring to the Green Software Foundation.
        </p>

        <div class="mt-8 rounded-xl border border-border bg-accent-lightest-2 p-8">
          <p class="text-base leading-relaxed text-primary-dark/80">
            "The Green Software Foundation is a non-profit with the mission to create a trusted ecosystem of people, standards, tooling, and best practices for building green software. The Foundation has been created for people who are in the business of building software. We are tasked with giving them answers about what they can do to reduce the software emissions they are responsible for. We create trust through representing a diverse mix of organisations. We welcome non-profits, for-profits, and academia and have members across all sectors and across the globe."
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <CTABanner
    heading="Need help with branding?"
    body="If you have any questions about using our brand, need assets in a different format, or want to check your materials before publishing, get in touch at help@greensoftware.foundation."
    ctaText="Contact us"
    ctaHref="mailto:help@greensoftware.foundation"
  />

  <Footer />
</Layout>
