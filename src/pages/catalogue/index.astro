---
import Layout from "@/layouts/showcase.astro";

// Layout components (parameterised — shared with homepage)
import Navbar from "@/components/navbar.astro";
import Footer from "@/components/footer.astro";
import Hero from "@/components/hero.astro";
import Testimonial from "@/components/testimonial.astro";

// Parameterised components (new / enhanced)
import Breadcrumb from "@/components/breadcrumb.astro";
import SplitCards from "@/components/split-cards.astro";
import CardGrid from "@/components/card-grid.astro";
import FeatureGrid from "@/components/feature-grid.astro";
import TextWithImage from "@/components/text-with-image.astro";
import CTACard from "@/components/cta-card.astro";
import TextBlock from "@/components/text-block.astro";
import TabbedSection from "@/components/tabbed-section.astro";
import CTABanner from "@/components/cta-banner.astro";
import LogoMarquee from "@/components/logo-marquee.astro";
import Timeline from "@/components/timeline.astro";
import TeamGrid from "@/components/team-grid.astro";
import StatsGrid from "@/components/stats-grid.astro";
import CommunityReach from "@/components/community-reach.astro";
import ResourceCards from "@/components/resource-cards.astro";

// Catalogue-only components (hardcoded content from microsites)
import Logo from "@/components/_catalogue/logo.astro";
import WhatSCI from "@/components/_catalogue/what-sci.astro";
import WhatWDPC from "@/components/_catalogue/what-wdpc.astro";
import WhatSOFT from "@/components/_catalogue/what-soft.astro";
import WhySCI from "@/components/_catalogue/why-sci.astro";
import HowItWorks from "@/components/_catalogue/how-it-works.astro";
import SuccessStories from "@/components/_catalogue/success-stories.astro";
import Research from "@/components/_catalogue/research.astro";
import AudienceBenefits from "@/components/_catalogue/audience-benefits.astro";
import Resources from "@/components/_catalogue/resources.astro";
import CatalogueTimeline from "@/components/_catalogue/timeline.astro";
import Team from "@/components/_catalogue/team.astro";
import AboutGSF from "@/components/_catalogue/about-gsf.astro";
import CatalogueCTABanner from "@/components/_catalogue/cta.astro";
import AudienceCards from "@/components/_catalogue/audience-cards.astro";
import Features from "@/components/_catalogue/features.astro";
import MissionCard from "@/components/_catalogue/mission-card.astro";
import ReadyToImplement from "@/components/_catalogue/ready-to-implement.astro";
import GetInvolved from "@/components/_catalogue/get-involved.astro";

// Markdown demo
import { Content as MarkdownDemo } from "../../content/demo/markdown-demo.md";

// ---- Data for parameterised component demos ----

const heroCtas = [
  { text: "Read Specification", href: "#", variant: "primary" as const },
  { text: "Learn More", href: "#", variant: "outline" as const },
];

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Standards", href: "/standards" },
  { label: "SCI for AI" },
];

const featureGridCardsFeatures = [
  { icon: "/assets/standards/sci-ai/transforming-1.svg", title: "End-to-End Lifecycle Coverage", description: "From data collection through model training to inference and deployment, SCI for AI covers every phase." },
  { icon: "/assets/standards/sci-ai/transforming-2.svg", title: "Methodology Transparency", description: "Clear boundary definitions and measurement methodologies ensure consistent, comparable results." },
  { icon: "/assets/standards/sci-ai/transforming-3.svg", title: "Actionable Insights", description: "Move beyond simple energy metrics to understand the true carbon impact of AI decisions." },
];

const featureGridBorderedFeatures = [
  { icon: "/assets/standards/sci-ai/transforming-1.svg", title: "Specification", description: "Read the technical specification for measuring carbon intensity." },
  { icon: "/assets/standards/sci-ai/transforming-2.svg", title: "Case Studies", description: "See how organisations are implementing the methodology." },
  { icon: "/assets/standards/sci-ai/transforming-3.svg", title: "Tools", description: "Open-source tools for measuring your software's carbon footprint." },
  { icon: "/assets/standards/sci-ai/transforming-4.svg", title: "Community", description: "Join the community and contribute to the standard." },
];

const featureGridPlainFeatures = [
  { icon: "/assets/standards/sci-ai/lifecycle-1.svg", title: "Inception & Design", description: "Carbon costs of planning, designing architectures, and selecting approaches." },
  { icon: "/assets/standards/sci-ai/lifecycle-2.svg", title: "Data for Development", description: "Energy used in data collection, cleaning, labelling, and storage." },
  { icon: "/assets/standards/sci-ai/lifecycle-3.svg", title: "Experimentation", description: "Resources consumed during model development, hyperparameter tuning, and testing." },
  { icon: "/assets/standards/sci-ai/lifecycle-4.svg", title: "Training", description: "The most energy-intensive phase — full model training, distributed computing, and GPU usage." },
  { icon: "/assets/standards/sci-ai/lifecycle-5.svg", title: "Deployment", description: "Ongoing inference costs, model serving, monitoring, and retraining cycles." },
];

const tabbedSectionTabs = [
  { value: "data", heading: "Data Layer", description: "Covers data collection, storage, preprocessing, and the carbon costs of data management throughout the AI pipeline." },
  { value: "compute", heading: "Compute Layer", description: "Measures the energy consumption and carbon intensity of compute resources used for training and inference." },
  { value: "model", heading: "Model Layer", description: "Evaluates architectural choices, model size, efficiency techniques, and their impact on carbon emissions." },
];

const cardGridCentreCards = [
  { icon: "/assets/standards/sci-ai/shape-1.svg", title: "Join Working Group", description: "Participate in developing and refining the specification.", ctaText: "Join Now", ctaHref: "#", featured: true },
  { icon: "/assets/standards/sci-ai/shape-2.svg", title: "Implement SCI", description: "Apply the methodology to your organisation's software.", ctaText: "Get Started", ctaHref: "#" },
  { icon: "/assets/standards/sci-ai/shape-3.svg", title: "Share Feedback", description: "Help improve the standard with your real-world experience.", ctaText: "Contribute", ctaHref: "#" },
];

const cardGridLeftCards = [
  { icon: "/assets/standards/sci-ai/explore-1.svg", title: "Green Software Patterns for AI", description: "A curated catalogue of actionable patterns for reducing the carbon footprint of AI systems.", ctaText: "Explore Patterns", ctaHref: "#" },
  { icon: "/assets/standards/sci-ai/explore-2.svg", title: "AI Carbon Measurement Tools", description: "Open-source tools and frameworks for implementing SCI for AI measurements.", ctaText: "View Tools", ctaHref: "#" },
  { icon: "/assets/standards/sci-ai/explore-3.svg", title: "Research & Case Studies", description: "Academic papers and industry implementations validating the SCI for AI approach.", ctaText: "Read Research", ctaHref: "#" },
];

const cardGridImageCards = [
  { imageSrc: "/assets/standards/sci-ai/hero-illustration.svg", icon: "/assets/standards/sci-ai/explore-1.svg", title: "Measuring AI Emissions", description: "How to apply the SCI methodology to your AI workloads.", ctaText: "Read More", ctaHref: "#" },
  { imageSrc: "/assets/standards/sci-ai/why-industry-impact.svg", icon: "/assets/standards/sci-ai/explore-2.svg", title: "The Business Case", description: "Why measuring AI carbon matters for your bottom line.", ctaText: "Read More", ctaHref: "#" },
];

const iconFeaturesDemo = [
  { icon: "/assets/standards/sci-ai/icon-cost.svg", description: '<span class="font-extrabold">Cost Optimisation</span> - Identify and eliminate wasteful computational overhead in AI workflows.' },
  { icon: "/assets/standards/sci-ai/icon-compliance.svg", description: '<span class="font-extrabold">Regulatory Compliance</span> - Stay ahead of emerging AI sustainability regulations and reporting requirements.' },
];

const splitCardsAttribution = { name: "Sample Attribution", role: "Role Title", company: "Organisation" };
---

<Layout
  title="Component Catalogue — Green Software Foundation"
  description="Internal component catalogue for the Green Software Foundation website."
>
  <!-- TABLE OF CONTENTS -->
  <nav class="sticky top-0 z-[100] bg-primary-darkest-2 text-white py-4 shadow-lg">
    <div class="container">
      <div class="flex items-center gap-4 flex-wrap">
        <span class="font-bold text-lg whitespace-nowrap">GSF Component Catalogue</span>
        <span class="text-accent">|</span>
        <div class="flex gap-3 flex-wrap text-sm">
          <a href="#navbar" class="hover:text-accent transition-colors">Navbar</a>
          <a href="#hero" class="hover:text-accent transition-colors">Hero</a>
          <a href="#breadcrumb" class="hover:text-accent transition-colors">Breadcrumb</a>
          <a href="#logo-marquee" class="hover:text-accent transition-colors">LogoMarquee</a>
          <a href="#text-block" class="hover:text-accent transition-colors">TextBlock</a>
          <a href="#text-with-image" class="hover:text-accent transition-colors">TextWithImage</a>
          <a href="#benefits-list" class="hover:text-accent transition-colors">BenefitsList</a>
          <a href="#equation-block" class="hover:text-accent transition-colors">EquationBlock</a>
          <a href="#feature-grid" class="hover:text-accent transition-colors">FeatureGrid</a>
          <a href="#success-stories" class="hover:text-accent transition-colors">SuccessStories</a>
          <a href="#testimonial" class="hover:text-accent transition-colors">Testimonial</a>
          <a href="#tabbed-section" class="hover:text-accent transition-colors">TabbedSection</a>
          <a href="#stats-grid" class="hover:text-accent transition-colors">StatsGrid</a>
          <a href="#audience-tabs" class="hover:text-accent transition-colors">AudienceTabs</a>
          <a href="#audience-cards" class="hover:text-accent transition-colors">AudienceCards</a>
          <a href="#card-grid" class="hover:text-accent transition-colors">CardGrid</a>
          <a href="#split-cards" class="hover:text-accent transition-colors">SplitCards</a>
          <a href="#resource-cards" class="hover:text-accent transition-colors">ResourceCards</a>
          <a href="#mission-card" class="hover:text-accent transition-colors">MissionCard</a>
          <a href="#cta-card" class="hover:text-accent transition-colors">CTACard</a>
          <a href="#cta-banner" class="hover:text-accent transition-colors">CTABanner</a>
          <a href="#community-reach" class="hover:text-accent transition-colors">CommunityReach</a>
          <a href="#get-started-cta" class="hover:text-accent transition-colors">GetStartedCTA</a>
          <a href="#get-involved" class="hover:text-accent transition-colors">GetInvolved</a>
          <a href="#timeline" class="hover:text-accent transition-colors">Timeline</a>
          <a href="#team-section" class="hover:text-accent transition-colors">TeamSection</a>
          <a href="#about-gsf" class="hover:text-accent transition-colors">AboutGSF</a>
          <a href="#footer" class="hover:text-accent transition-colors">Footer</a>
          <span class="text-accent">|</span>
          <a href="#markdown" class="hover:text-accent transition-colors">Markdown</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- INTRO -->
  <section class="bg-white py-16 md:py-24">
    <div class="container max-w-4xl text-center">
      <h1 class="text-4xl font-bold text-primary-darker md:text-5xl mb-4">
        GSF Component Catalogue
      </h1>
      <p class="text-lg text-primary-dark mb-6">
        Every reusable component from the GSF website and microsites (SCI, WDPC, SOFT, SCI for AI), displayed with live examples.
        Use the component names as labels when specifying page layouts.
      </p>
      <p class="text-sm text-gray-darker">
        Scroll down to browse each component, or use the navigation bar above to jump to a specific one.
      </p>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 1. NAVBAR -->
  <!-- ============================================================ -->
  <div id="navbar" class="scroll-mt-20">
    <div class="bg-accent-lighter border-l-4 border-accent py-4 px-6 mx-4 my-8 rounded-r-lg">
      <h2 class="text-2xl font-bold text-primary-darker">1. Navbar</h2>
      <p class="text-sm text-primary-dark mt-1">
        <strong>File:</strong> <code>src/components/navbar.astro</code> + <code>src/components/react/navbar.tsx</code>
      </p>
      <p class="mt-2">Fixed navigation bar. Top row: "Project By [GSF Logo]". Bottom row: project logo, nav links, GitHub button. Mobile: hamburger menu opens a Sheet drawer. Used on every page of every microsite.</p>
      <p class="mt-1 text-sm"><strong>Props:</strong> <code>navItems</code>, <code>logoSrc</code>, <code>topBar</code> ("project-by"|"utility"|"none"), <code>ctaText</code></p>
      <p class="mt-1 text-sm"><strong>Used on:</strong> All pages</p>
    </div>
  </div>
  <Navbar />

  <!-- ============================================================ -->
  <!-- 2. HERO -->
  <!-- ============================================================ -->
  <div id="hero" class="scroll-mt-20">
    <div class="bg-accent-lighter border-l-4 border-accent py-4 px-6 mx-4 my-8 rounded-r-lg">
      <h2 class="text-2xl font-bold text-primary-darker">2. Hero</h2>
      <p class="text-sm text-primary-dark mt-1">
        <strong>File:</strong> <code>src/components/hero.astro</code>
      </p>
      <p class="mt-2">Full-width hero with cream background. Left: H1 headline, subtitle, body text, 1-2 CTA buttons. Right: SVG illustration. Supports <code>headingSuffix</code> for text after the accent span (e.g. "Measure <strong>AI's Carbon</strong> with Purpose").</p>
      <p class="mt-1 text-sm"><strong>Props:</strong> <code>heading</code>, <code>headingAccent</code>, <code>headingSuffix</code>, <code>body</code>, <code>ctas[]</code>, <code>imageSrc</code>, <code>bgClass</code></p>
      <p class="mt-1 text-sm"><strong>Used on:</strong> All microsites and homepage (top of every page)</p>
    </div>
  </div>
  <Hero
    heading="Measure"
    headingAccent="AI's Carbon Footprint"
    headingSuffix="with Purpose"
    body="A standardized specification extending the Software Carbon Intensity methodology to measure the carbon emissions of AI systems throughout their lifecycle."
    ctas={heroCtas}
    imageSrc="/assets/standards/sci-ai/hero-illustration.svg"
  />

  <!-- ============================================================ -->
  <!-- 3. BREADCRUMB -->
  <!-- ============================================================ -->
  <div id="breadcrumb" class="scroll-mt-20">
    <div class="bg-accent-lighter border-l-4 border-accent py-4 px-6 mx-4 my-8 rounded-r-lg">
      <h2 class="text-2xl font-bold text-primary-darker">3. Breadcrumb</h2>
      <p class="text-sm text-primary-dark mt-1">
        <strong>File:</strong> <code>src/components/breadcrumb.astro</code>
      </p>
      <p class="mt-2">Simple breadcrumb navigation with <code>/</code> separators. Last item (no href) renders as the current page in bold. Useful for nested pages like <code>/standards/sci/</code>.</p>
      <p class="mt-1 text-sm"><strong>Props:</strong> <code>items[]</code> (label, href?), <code>bgClass</code></p>
      <p class="mt-1 text-sm"><strong>Used on:</strong> SCI, WDPC, SOFT, SCI for AI (all standards subpages)</p>
    </div>
  </div>
  <Breadcrumb items={breadcrumbItems} />

  <!-- ============================================================ -->
  <!-- 4. LOGO MARQUEE -->
  <!-- ============================================================ -->
  <div id="logo-marquee" class="scroll-mt-20">
    <div class="bg-accent-lighter border-l-4 border-accent py-4 px-6 mx-4 my-8 rounded-r-lg">
      <h2 class="text-2xl font-bold text-primary-darker">4. LogoMarquee</h2>
      <p class="text-sm text-primary-dark mt-1">
        <strong>File:</strong> <code>src/components/logo-marquee.astro</code>
      </p>
      <p class="mt-2">Two rows of member logos scrolling horizontally in opposite directions (infinite marquee animation). Logos fetched from Notion at build time.</p>
      <p class="mt-1 text-sm"><strong>Props:</strong> <code>heading</code>, <code>greyscale</code>, <code>bgClass</code></p>
      <p class="mt-1 text-sm"><strong>Used on:</strong> SCI, WDPC, SOFT, SCI for AI, Homepage</p>
    </div>
  </div>
  <Logo />

  <!-- ============================================================ -->
  <!-- 5. TEXT BLOCK -->
  <!-- ============================================================ -->
  <div id="text-block" class="scroll-mt-20">
    <div class="bg-accent-lighter border-l-4 border-accent py-4 px-6 mx-4 my-8 rounded-r-lg">
      <h2 class="text-2xl font-bold text-primary-darker">5. TextBlock</h2>
      <p class="text-sm text-primary-dark mt-1">
        <strong>File:</strong> <code>src/components/text-block.astro</code>
      </p>
      <p class="mt-2">Centred heading and body text. Supports <code>*accent*</code> syntax in headings for green-highlighted words. Optional image and card wrapping. Good for section introductions.</p>
      <p class="mt-1 text-sm"><strong>Props:</strong> <code>heading</code> (supports <code>*accent*</code>), <code>body</code>, <code>imageSrc</code>, <code>card</code>, <code>compact</code></p>
      <p class="mt-1 text-sm"><strong>Used on:</strong> SCI, WDPC, SOFT, SCI for AI, Homepage</p>
    </div>
  </div>

  <!-- Variant A: Centred Text + Scrolling Ticker -->
  <div class="scroll-mt-20">
    <div class="bg-blue-50 border-l-4 border-blue-400 py-3 px-6 mx-8 my-4 rounded-r-lg">
      <h3 class="text-lg font-bold text-blue-900">Variant A: Centred Text + Ticker (legacy)</h3>
      <p class="text-sm text-blue-800 mt-1">
        <strong>File:</strong> <code>src/components/_catalogue/what-sci.astro</code>
      </p>
    </div>
  </div>
  <WhatSCI />

  <!-- Variant B: Centred Text + 2x2 Feature Grid -->
  <div class="scroll-mt-20">
    <div class="bg-blue-50 border-l-4 border-blue-400 py-3 px-6 mx-8 my-4 rounded-r-lg">
      <h3 class="text-lg font-bold text-blue-900">Variant B: Centred Text + Feature Grid (legacy)</h3>
      <p class="text-sm text-blue-800 mt-1">
        <strong>File:</strong> <code>src/components/_catalogue/what-wdpc.astro</code>
      </p>
    </div>
  </div>
  <WhatWDPC />

  <!-- Variant C: Two-Column with Image -->
  <div class="scroll-mt-20">
    <div class="bg-blue-50 border-l-4 border-blue-400 py-3 px-6 mx-8 my-4 rounded-r-lg">
      <h3 class="text-lg font-bold text-blue-900">Variant C: Two-Column with Image (legacy)</h3>
      <p class="text-sm text-blue-800 mt-1">
        <strong>File:</strong> <code>src/components/_catalogue/what-soft.astro</code>
      </p>
    </div>
  </div>
  <WhatSOFT />

  <!-- Parameterised TextBlock -->
  <div class="scroll-mt-20">
    <div class="bg-blue-50 border-l-4 border-blue-400 py-3 px-6 mx-8 my-4 rounded-r-lg">
      <h3 class="text-lg font-bold text-blue-900">Parameterised TextBlock</h3>
      <p class="text-sm text-blue-800 mt-1">Uses <code>*accent*</code> heading syntax and compact mode</p>
    </div>
  </div>
  <TextBlock
    heading="Why *SCI for AI* Matters"
    body="Artificial intelligence is transforming industries at an unprecedented pace, but its environmental impact remains largely unmeasured and unaddressed."
    compact
  />

  <!-- ============================================================ -->
  <!-- 6. TEXT WITH IMAGE -->
  <!-- ============================================================ -->
  <div id="text-with-image" class="scroll-mt-20">
    <div class="bg-accent-lighter border-l-4 border-accent py-4 px-6 mx-4 my-8 rounded-r-lg">
      <h2 class="text-2xl font-bold text-primary-darker">6. TextWithImage</h2>
      <p class="text-sm text-primary-dark mt-1">
        <strong>File:</strong> <code>src/components/text-with-image.astro</code>
      </p>
      <p class="mt-2">Two-column layout — text on one side, illustration on the other. Supports two heading styles: <code>bold</code> (default, extrabold with accent span) and <code>light</code> (semibold, all green). Also supports icon feature rows with optional background icon. Use <code>reversed</code> to flip image to left.</p>
      <p class="mt-1 text-sm"><strong>Props:</strong> <code>badge</code>, <code>heading</code>, <code>headingAccent</code>, <code>stats[]</code>, <code>body</code>, <code>iconFeatures[]</code>, <code>iconFeaturesBgIcon</code>, <code>ctaText</code>, <code>imageSrc</code>, <code>reversed</code>, <code>headingStyle</code> ("bold"|"light")</p>
      <p class="mt-1 text-sm"><strong>Used on:</strong> SCI, WDPC, SOFT, SCI for AI, Homepage</p>
    </div>
  </div>

  <!-- Default (bold) heading style -->
  <div class="scroll-mt-20">
    <div class="bg-blue-50 border-l-4 border-blue-400 py-3 px-6 mx-8 my-4 rounded-r-lg">
      <h3 class="text-lg font-bold text-blue-900">Variant A: Bold heading (default)</h3>
      <p class="text-sm text-blue-800 mt-1">Extrabold heading with accent span. Standard layout.</p>
    </div>
  </div>
  <TextWithImage
    badge="MEASUREMENT"
    heading="Industry"
    headingAccent="Impact"
    body="The Software Carbon Intensity specification provides a consistent methodology for quantifying software's carbon emissions, enabling organisations to make data-driven decisions."
    imageSrc="/assets/standards/sci-ai/why-industry-impact.svg"
  />

  <!-- Light heading style -->
  <div id="benefits-list" class="scroll-mt-20">
    <div class="bg-blue-50 border-l-4 border-blue-400 py-3 px-6 mx-8 my-4 rounded-r-lg">
      <h3 class="text-lg font-bold text-blue-900">Variant B: Light heading style</h3>
      <p class="text-sm text-blue-800 mt-1">Semibold, all-green heading. Used for lighter sections on SCI for AI.</p>
    </div>
  </div>
  <TextWithImage
    heading="Industry"
    headingAccent="Impact"
    headingStyle="light"
    body="AI systems are rapidly becoming one of the most energy-intensive technologies. The SCI for AI specification brings transparency to AI's carbon emissions."
    imageSrc="/assets/standards/sci-ai/why-industry-impact.svg"
  />

  <!-- Icon features + reversed -->
  <div class="scroll-mt-20">
    <div class="bg-blue-50 border-l-4 border-blue-400 py-3 px-6 mx-8 my-4 rounded-r-lg">
      <h3 class="text-lg font-bold text-blue-900">Variant C: Icon features + reversed layout</h3>
      <p class="text-sm text-blue-800 mt-1">Image on left, icon feature rows on right with decorative background icons.</p>
    </div>
  </div>
  <TextWithImage
    heading="Business"
    headingAccent="Benefits"
    headingStyle="light"
    reversed
    iconFeatures={iconFeaturesDemo}
    iconFeaturesBgIcon="/assets/standards/sci-ai/icon-feature-bg.svg"
    imageSrc="/assets/standards/sci-ai/why-business-benefits.svg"
  />

  <!-- Legacy WhySCI demo -->
  <div class="scroll-mt-20">
    <div class="bg-blue-50 border-l-4 border-blue-400 py-3 px-6 mx-8 my-4 rounded-r-lg">
      <h3 class="text-lg font-bold text-blue-900">Legacy: WhySCI (hardcoded)</h3>
    </div>
  </div>
  <WhySCI />

  <!-- ============================================================ -->
  <!-- 7. EQUATION BLOCK -->
  <!-- ============================================================ -->
  <div id="equation-block" class="scroll-mt-20">
    <div class="bg-accent-lighter border-l-4 border-accent py-4 px-6 mx-4 my-8 rounded-r-lg">
      <h2 class="text-2xl font-bold text-primary-darker">7. EquationBlock</h2>
      <p class="text-sm text-primary-dark mt-1">
        <strong>File:</strong> <code>src/components/_catalogue/how-it-works.astro</code>
      </p>
      <p class="mt-2">Centred section with heading, explanatory text, then a large styled equation display (e.g., "SCI = (E x I + M) per R"). Great for any formula, methodology, or key concept that needs visual emphasis.</p>
      <p class="mt-1 text-sm"><strong>Used on:</strong> SCI only. Unique and reusable for any formula/concept display.</p>
    </div>
  </div>
  <HowItWorks />

  <!-- ============================================================ -->
  <!-- 8. FEATURE GRID -->
  <!-- ============================================================ -->
  <div id="feature-grid" class="scroll-mt-20">
    <div class="bg-accent-lighter border-l-4 border-accent py-4 px-6 mx-4 my-8 rounded-r-lg">
      <h2 class="text-2xl font-bold text-primary-darker">8. FeatureGrid</h2>
      <p class="text-sm text-primary-dark mt-1">
        <strong>File:</strong> <code>src/components/feature-grid.astro</code>
      </p>
      <p class="mt-2">Grid of feature items with three variants: <code>cards</code> (rounded card grid), <code>bordered</code> (centred card with bordered grid), and <code>plain</code> (left-aligned heading with vertical dividers). Supports 2-5 columns and <code>*accent*</code> headings.</p>
      <p class="mt-1 text-sm"><strong>Props:</strong> <code>heading</code> (supports <code>*accent*</code>), <code>body</code>, <code>bodyHtml</code>, <code>features[]</code> (icon, title, description, linkText, linkHref), <code>columns</code> (2|3|4|5), <code>variant</code> ("cards"|"bordered"|"plain"), <code>compact</code></p>
