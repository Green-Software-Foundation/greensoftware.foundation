---
import Layout from "@/layouts/showcase.astro";
import { navItems } from "@/lib/nav-items";

import Navbar from "@/components/navbar.astro";
import Footer from "@/components/footer.astro";
import NewsletterForm from "@/components/react/newsletter-form";
import { Button } from "@/components/ui/button";
---

<Layout
  title="Newsletter — Green Software Foundation"
  description="Subscribe to the Green Software Foundation newsletter for weekly insights on sustainable software, industry news, and community updates."
>
  <Navbar
    logoSrc="/assets/gsf-logo-full.svg"
    logoAlt="Green Software Foundation"
    logoHref="/"
    topBar="none"
    showSearch
    navItems={navItems}
  />

  <!-- Newsletter signup section -->
  <section class="bg-accent-lightest-2 py-16 md:py-24">
    <div class="container">
      <div class="mx-auto max-w-2xl text-center">
        <span class="inline-block rounded-full bg-accent-lighter px-3 py-1 text-xs font-semibold text-accent-darker">
          NEWSLETTER
        </span>
        <h1 class="mt-4 text-3xl font-extrabold md:text-4xl lg:text-5xl">
          Stay ahead of the <span class="text-primary">green software</span> movement
        </h1>
        <p class="mt-4 text-lg text-primary-dark">
          Join thousands of developers, sustainability leaders, and technology professionals who receive our weekly newsletter packed with insights, best practices, and the latest developments in green software.
        </p>
      </div>

      <div class="mx-auto mt-10 max-w-lg">
        <div class="rounded-2xl border bg-white p-8 shadow-sm md:p-10">
          <NewsletterForm
            client:visible
            variant="inline"
            showName
            namePlaceholder="First name"
            emailPlaceholder="you@example.com"
            buttonText="Subscribe"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- What you'll get -->
  <section class="bg-white py-16 md:py-20">
    <div class="container">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-2xl font-semibold md:text-3xl">
          What you'll <span class="font-bold text-primary">receive</span>
        </h2>
        <p class="mt-4 text-primary-dark">
          Our newsletter is sent weekly and includes a curated mix of content to keep you informed and inspired.
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-4xl gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border bg-accent-lightest-2 p-6">
          <h3 class="text-lg font-bold text-primary">Industry news</h3>
          <p class="mt-2 text-sm text-primary-dark">The latest developments in green software standards, policy, and regulation from around the world.</p>
        </div>
        <div class="rounded-xl border bg-accent-lightest-2 p-6">
          <h3 class="text-lg font-bold text-primary">Technical insights</h3>
          <p class="mt-2 text-sm text-primary-dark">Deep dives into carbon-aware computing, energy efficiency patterns, and sustainable architecture.</p>
        </div>
        <div class="rounded-xl border bg-accent-lightest-2 p-6">
          <h3 class="text-lg font-bold text-primary">Community updates</h3>
          <p class="mt-2 text-sm text-primary-dark">Member stories, upcoming events, working group progress, and ways to get involved.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Membership CTA -->
  <section class="bg-accent-lightest-2 py-16 md:py-20">
    <div class="container">
      <div class="mx-auto max-w-3xl rounded-2xl bg-primary-darker p-8 text-center text-white md:p-12">
        <h2 class="text-2xl font-bold md:text-3xl">
          Interested in going further?
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-white/80">
          Our members are leading the charge in making software sustainable. From steering the development of global standards to accessing exclusive resources and networking opportunities, membership unlocks the full potential of the green software movement.
        </p>
        <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
          <a href="/membership/">
            <Button variant="secondary" className="w-full sm:w-auto">Explore membership</Button>
          </a>
          <a href="/articles/">
            <Button variant="primary-invert" className="w-full sm:w-auto">Read member stories</Button>
          </a>
        </div>
        <p class="mt-6 text-xs text-white/50">
          The Green Software Foundation has 50+ member organizations including Accenture, GitHub, Goldman Sachs, Microsoft, NTT DATA, Thoughtworks, and UBS.
        </p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
