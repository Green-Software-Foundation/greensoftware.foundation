---
import Layout from "@/layouts/showcase.astro";
import { navItems } from "@/lib/nav-items";

import Navbar from "@/components/navbar.astro";
import Hero from "@/components/hero.astro";
import CTACard from "@/components/cta-card.astro";
import FeatureGrid from "@/components/feature-grid.astro";
import TextBlock from "@/components/text-block.astro";
import TextWithImage from "@/components/text-with-image.astro";
import TabbedSection from "@/components/tabbed-section.astro";
import CardGrid from "@/components/card-grid.astro";
import Timeline from "@/components/timeline.astro";
import TeamGrid from "@/components/team-grid.astro";
import ArticleCarousel from "@/components/article-carousel.astro";
import Testimonial from "@/components/testimonial.astro";
import CTABanner from "@/components/cta-banner.astro";
import Breadcrumb from "@/components/breadcrumb.astro";
import Footer from "@/components/footer.astro";

import projects from "@/data/projects.json";

const sciWebProject = projects.find(p => p.slug === "sci-web");
const parentWg = projects.find(p => p.name === sciWebProject?.parent);

// Pull SCI for Web tagged articles for the carousel
import { getCollection } from "astro:content";
import { articleUrl } from "@/lib/utils";
import membersData from "@/data/members.json";
const logoMap = new Map((membersData as any[]).filter((m: any) => m.active && m.logo && !m.hideLogo).map((m: any) => [m.companyName.toLowerCase(), `/assets/${m.logo}`]));
const allArticles = await getCollection("articles", (a) => a.data.published !== false);
const carouselArticles = allArticles
  .filter(a => (a.data.tags || []).map((t: string) => t.toLowerCase()).includes("sci-web"))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map(a => ({
    title: a.data.title,
    description: a.data.summary || a.data.teaserText || "",
    imageSrc: a.data.mainImage?.src || "/assets/hero-illustration.svg",
    href: articleUrl(a.id),
    cta: "Read more →",
    organizations: (a.data.organizations || []).map((name: string) => ({
      name,
      logoSrc: logoMap.get(name.toLowerCase()),
    })),
  }));
---

<Layout
  title="SCI for Web — Software Carbon Intensity for the Web | Green Software Foundation"
  description="A standardised methodology for measuring the carbon intensity of web applications, covering servers, networks, third-party services, and end-user devices."
>
  <Navbar
    logoSrc="/assets/gsf-logo-full.svg"
    logoAlt="Green Software Foundation"
    logoHref="/"
    topBar="none"
    showSearch
    navItems={navItems}
    ctaText="Discuss your challenges"
    ctaHref="/membership/"
  />

  <Breadcrumb items={[
    { label: "Home", href: "/" },
    { label: "Standards", href: "/standards/" },
    { label: "SCI for Web" },
  ]} />

  <!-- Hero -->
  <Hero
    badges={[
      ...(parentWg ? [{ text: `A ${parentWg.name} Project` }] : []),
      ...(sciWebProject?.lifecycle ? [{ text: sciWebProject.lifecycle, variant: "dark" as const }] : []),
    ]}
    heading="Measure the Carbon Impact of"
    headingAccent="the Web"
    body="Almost all of us use the web daily, and like everything else, we need to make using it more sustainable. SCI for Web extends the ISO-accredited Software Carbon Intensity standard to web applications — covering servers, networks, third-party services, and end-user devices."
    ctas={[
      { text: "Read the Design Document", variant: "primary", href: "/policy/research/sci-web-assembly-report/" },
      { text: "Get Involved", variant: "outline", href: "https://directory.greensoftware.foundation/projects/software-carbon-intensity-for-web-(sci-for-web)/" },
    ]}
    imageSrc="/assets/standards/sci-web/hero-illustration.svg"
    imageAlt="SCI for Web illustration"
    bgClass="bg-accent-lightest-2"
    id="overview"
  />

  <!-- What is SCI for Web? -->
  <CTACard
    heading="What is SCI for Web?"
    body="SCI for Web is a domain-specific extension of the SCI specification (ISO/IEC 21031:2024) for measuring the carbon intensity of web applications. A web application is characterised by three essential criteria: content and functionality delivered over HTTP/HTTPS protocols, rendering and execution occurring primarily within web browser environments, and interfaces designed for direct human interaction rather than exclusively machine-to-machine communication."
    imageSrc="/assets/standards/sci/why-wdpc-feat-1.svg"
    imageAlt="What is SCI for Web illustration"
  />

  <!-- Why the Web Needs This -->
  <section class="py-8 md:py-10 bg-accent-lightest-2">
    <div class="container">
      <div class="mx-auto max-w-5xl text-center">
        <h2 class="text-2xl font-semibold md:text-3xl lg:text-4xl">
          Why the Web Needs <span class="font-bold text-primary">SCI for Web</span>
        </h2>
        <p class="mt-6 text-lg leading-relaxed md:text-xl">
          As the <a href="/standards/sci/" class="text-primary underline hover:no-underline">SCI specification</a> matured into an ISO standard, GSF members recognised that a domain-specific, SCI-aligned approach was needed for web applications. Tools and frameworks like the <a href="https://sustainablewebdesign.org/" class="text-primary underline hover:no-underline" target="_blank" rel="noopener">Sustainable Web Design Model</a>, <a href="https://www.thegreenwebfoundation.org/co2-js/" class="text-primary underline hover:no-underline" target="_blank" rel="noopener">CO2.js</a>, and the <a href="https://w3c.github.io/sustyweb/" class="text-primary underline hover:no-underline" target="_blank" rel="noopener">W3C Web Sustainability Guidelines</a> have made web emissions visible and established foundational methodologies that thousands of practitioners use. But as organisations move from awareness to accountability, the industry needs approaches that support optimisation decisions across the full delivery chain — including servers, browsers, and third-party services.
        </p>
      </div>
    </div>
  </section>

  <!-- The SCI Equation Applied to Web -->
  <section class="py-12 md:py-16 lg:py-20 bg-accent-lighter/30">
    <div class="container">
      <div class="mx-auto max-w-4xl text-center">
        <h2 class="mb-6 text-2xl font-semibold md:text-3xl lg:text-4xl">
          The SCI Formula, Applied to the Web
        </h2>
        <p class="text-lg md:text-xl">
          SCI for Web uses the same core formula as the parent <a href="/standards/sci/" class="text-primary underline hover:no-underline">SCI standard</a>, but defines web-appropriate boundaries across servers, networks, third parties, and end-user devices — with functional units that reflect delivered web functionality.
        </p>

        <div class="my-10 rounded-xl bg-white p-8 shadow-sm md:my-12">
          <p class="text-3xl font-bold text-primary md:text-4xl lg:text-5xl font-mono">
            SCI = (E &times; I + M) per R
          </p>
        </div>

        <div class="grid grid-cols-1 gap-6 text-left md:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-xl border bg-white p-5">
            <h3 class="font-bold text-primary text-lg">E — Energy</h3>
            <p class="mt-2 text-sm text-gray-darker">Energy consumed across the full delivery chain: servers, CDNs, networks, and end-user devices including browsers.</p>
          </div>
          <div class="rounded-xl border bg-white p-5">
            <h3 class="font-bold text-primary text-lg">I — Carbon Intensity</h3>
            <p class="mt-2 text-sm text-gray-darker">The carbon intensity of the energy used, based on location and time — accounting for the global, distributed nature of web delivery.</p>
          </div>
          <div class="rounded-xl border bg-white p-5">
            <h3 class="font-bold text-primary text-lg">M — Embodied</h3>
            <p class="mt-2 text-sm text-gray-darker">Embodied emissions from manufacturing the hardware that serves, delivers, and renders web content.</p>
          </div>
          <div class="rounded-xl border bg-white p-5">
            <h3 class="font-bold text-primary text-lg">R — Functional Unit</h3>
            <p class="mt-2 text-sm text-gray-darker">A web-appropriate functional unit — per page view, per transaction, per session — that reveals true efficiency.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Problem -->
  <FeatureGrid
    heading="The *Measurement Gap*"
    body="Existing tools have made web emissions visible, but critical gaps remain."
    columns={4}
    variant="bordered"
    features={[
      {
        icon: "/assets/standards/sci/shape-icon-1.svg",
        title: "No Standard Boundaries",
        description: "Different tools measure different things, making results incomparable across organisations.",
      },
      {
        icon: "/assets/standards/sci/shape-icon-2.svg",
        title: "Third Parties Are Invisible",
        description: "Analytics, advertising, CDNs, and authentication consume energy on both servers and client devices but are excluded from most measurements.",
      },
      {
        icon: "/assets/standards/sci/shape-icon-3.svg",
        title: "Totals, Not Rates",
        description: "Existing approaches measure total emissions rather than carbon per functional unit, making it impossible to reward efficiency.",
      },
      {
        icon: "/assets/standards/sci/shape-icon-4.svg",
        title: "No Validation",
        description: "Without mandatory disclosure of boundaries, assumptions, and methods, reduction claims cannot be verified or compared.",
      },
    ]}
    bgClass="bg-accent-lightest-2"
  />

  <!-- How SCI for Web Solves This -->
  <TextBlock
    heading="How *SCI for Web* Solves This"
    body="SCI provides a strong foundation to measure and reduce web emissions because it is clear about boundaries (what is in scope and what is not), rates (carbon per functional unit, not just totals), and reporting (disclosed methodology so results are comparable and defensible). SCI for Web extends the parent specification to web-specific contexts."
    compact
    bgClass="bg-accent-lightest-2"
  />

  <!-- Evaluation Criteria -->
  <FeatureGrid
    heading="Evaluation *Criteria*"
    body="The assembly agreed on key principles to ensure that optimising SCI for Web scores aligns with genuine carbon reduction."
    columns={3}
    variant="bordered"
    features={[
      {
        icon: "/assets/standards/sci/co2-icon.svg",
        title: "Accuracy Proportionate to Control",
        description: "Directly measured components require higher accuracy than modelled estimates. This ensures confident decision-making where practitioners have the most influence.",
      },
      {
        icon: "/assets/standards/sci/cost-icon.svg",
        title: "Mandatory Disclosure",
        description: "Boundaries, assumptions, data sources, and methods must be clearly stated. This prevents gaming — for example, measurement approaches that automatically credit 'green hosting' based on provider claims allow scores to improve without reducing actual energy use.",
      },
      {
        icon: "/assets/standards/sci/grid-icon.svg",
        title: "Integration Over Complexity",
        description: "Implementation should fit existing workflows, not require new toolchains. Workflow integration removes adoption barriers, and accurate measurement enables confident decision-making.",
      },
    ]}
    bgClass="bg-accent-lightest-2"
  />

  <!-- Mission Card -->
  <section class="py-8 md:py-12 lg:py-16">
    <div class="container">
      <div class="relative rounded-4xl border-3 border-accent-lighter px-12 py-12 backdrop-blur-sm md:px-20 md:py-16">
        <div class="absolute -top-6 left-1/2 -translate-x-1/2 transform rounded-full bg-accent-lightest-2">
          <img src="/assets/standards/sci/up.svg" class="h-12 w-16 md:h-14 md:w-24" />
        </div>
        <div class="text-center">
          <p class="text-lg font-medium text-primary-dark italic md:text-xl">
            A specification that is technically accurate but unused won't serve its purpose, and a widely used metric that lacks credibility also won't serve the purpose.
          </p>
        </div>
        <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 transform rounded-full bg-accent-lightest-2">
          <img src="/assets/standards/sci/up.svg" class="h-12 w-16 md:h-14 md:w-24 rotate-180" />
        </div>
      </div>
    </div>
  </section>

  <!-- W3C Partnership -->
  <TextWithImage
    heading="Built in Collaboration with"
    headingAccent="the W3C"
    headingStyle="light"
    body="SCI for Web is developed in formal collaboration with the World Wide Web Consortium (W3C). This partnership combines GSF's expertise in software carbon measurement with W3C's global reach in web standards — brokered by the Green Web Foundation, who are active members of both communities. GSF manages the specification through its consensus-driven process, while W3C's Sustainable Web Interest Group provides feedback and insights."
    imageSrc="/assets/standards/sci/why-wdpc-feat-3.svg"
    imageAlt="W3C collaboration illustration"
    bgClass="bg-accent-lightest-2"
  />

  <!-- Scope -->
  <TextWithImage
    heading="Web Applications"
    headingAccent="In Scope"
    headingStyle="light"
    body="The scope encompasses the full spectrum of browser-based applications regardless of architectural sophistication. The distinguishing principle is browser-mediated human interaction: if users primarily access functionality through web browsers to accomplish tasks or consume content, the application falls within scope. This definition is intentionally platform-independent and technology-agnostic, focusing on delivery mechanism and user interaction patterns rather than specific implementation technologies."
    imageSrc="/assets/standards/sci/why-wdpc-feat-2.svg"
    imageAlt="Web applications in scope"
    reversed
    iconFeatures={[
      {
        icon: "/assets/standards/sci/transforming-icon-1.svg",
        description: "Static content websites, dynamic platforms, and single-page applications (SPAs)",
      },
      {
        icon: "/assets/standards/sci/transforming-icon-2.svg",
        description: "Server-side rendered applications, e-commerce systems, and media streaming services",
      },
      {
        icon: "/assets/standards/sci/transforming-icon-3.svg",
        description: "Real-time collaborative tools and browser-based management dashboards",
      },
      {
        icon: "/assets/standards/sci/transforming-icon-4.svg",
        description: "APIs accessed primarily through browser interfaces (pure machine-to-machine APIs are out of scope and should use the base SCI methodology)",
      },
    ]}
    iconFeaturesBgIcon="/assets/standards/sci/icon-bg.svg"
    bgClass="bg-accent-lightest-2"
  />

  <!-- Who It's For -->
  <TabbedSection
    badge="WHO IT'S FOR"
    heading="Built for Every Role in Web Development"
    tabs={[
      {
        value: "frontend",
        heading: "Frontend Developers & Designers",
        description: "Make sustainability part of your development workflow without sacrificing user experience or performance. SCI for Web helps you understand the carbon impact of client-side code, asset delivery, third-party scripts, and rendering approaches — so you can make informed choices about progressive enhancement, image optimisation, and framework selection.",
        image: { src: "/assets/standards/sci/why-wdpc-feat-1.svg" },
      },
      {
        value: "backend",
        heading: "Backend & Infrastructure Engineers",
        description: "Understand the full server-side contribution to web emissions — from compute and storage to geographic hosting decisions and carbon intensity exposure. SCI for Web gives you a framework to measure and optimise database efficiency, caching strategies, right-sized infrastructure, and deployment processes.",
        image: { src: "/assets/standards/sci/why-wdpc-feat-2.svg" },
      },
      {
        value: "product",
        heading: "Product Owners & Technical Managers",
        description: "Turn sustainability commitments into measurable web performance metrics. SCI for Web helps you set environmental budgets, make informed vendor decisions based on emissions data, and practice feature gardening — regularly auditing what you build to ensure every feature justifies its carbon cost.",
        image: { src: "/assets/standards/sci/why-wdpc-feat-3.svg" },
      },
    ]}
    bgClass="bg-accent-lighter/10"
  />

  <!-- Third-Party Transparency -->
  <TextWithImage
    heading="Third-Party"
    headingAccent="Transparency"
    headingStyle="light"
    body="Modern web applications rely heavily on third-party services — analytics, advertising, CDNs, authentication, and payments — that consume energy on both servers and end-user devices. SCI for Web requires these dependencies to be included in the measurement boundary because excluding them hides a significant portion of a website's true carbon footprint. Where precise energy data isn't available from suppliers, practitioners can use industry default values as long as they disclose that estimates were used. The goal is to create market pressure: when organisations start measuring third-party emissions, suppliers have an incentive to publish their own energy data and improve efficiency."
    imageSrc="/assets/standards/sci/why-wdpc-feat-1.svg"
    imageAlt="Third-party transparency illustration"
    bgClass="bg-accent-lightest-2"
  />

  <!-- Incremental Adoption -->
  <TextWithImage
    heading="Principles, Not"
    headingAccent="Prescriptions"
    headingStyle="light"
    body="SCI for Web describes principles and patterns, not prescriptive engineering requirements. Teams should evaluate these within their own context and implement them in ways that suit their architecture and constraints. Crucially, adoption can be incremental: start by measuring the components you directly control — client-side code and server infrastructure — then progressively expand to include network transfer and third-party services. The only requirement is transparency: your disclosed methodology must clearly state which components are measured, which are estimated, and which are excluded."
    imageSrc="/assets/standards/sci/why-wdpc-feat-3.svg"
    imageAlt="Incremental adoption illustration"
    reversed
    bgClass="bg-accent-lightest-2"
  />

  <!-- Testimonial -->
  <Testimonial
    quote="Almost all of us use the web daily, and like everything else, we need to make using it more sustainable. By defining a standard for measuring website emissions, we make it easier for people to request greener digital services, for responsible technologists to build them, and to reach the fossil-free internet we all need."
    author="GSF–W3C Collaboration"
    title="Announcement"
    company="September 2025"
  />

  <!-- Success Criteria -->
  <FeatureGrid
    heading="How We'll Know *It's Working*"
    body="SCI for Web will be successful when it drives real change across the web ecosystem."
    columns={2}
    variant="bordered"
    features={[
      {
        icon: "/assets/standards/sci/transforming-icon-1.svg",
        title: "Workflow Integration",
        description: "Developers can integrate SCI for Web into existing workflows without specialised training.",
      },
      {
        icon: "/assets/standards/sci/transforming-icon-2.svg",
        title: "Informed Optimisation",
        description: "Organisations use measurements to prioritise which optimisations deliver the most carbon reduction.",
      },
      {
        icon: "/assets/standards/sci/transforming-icon-3.svg",
        title: "Third-Party Transparency",
        description: "Third-party service providers start publishing energy data because customers need it for calculations.",
      },
      {
        icon: "/assets/standards/sci/transforming-icon-4.svg",
        title: "Open-Source Tooling",
        description: "Multiple open-source tools emerge to make measurement progressively easier.",
      },
    ]}
    bgClass="bg-accent-lightest-2"
  />

  <!-- Timeline -->
  <Timeline
    heading="The Journey to *Web Sustainability Measurement*"
    items={[
      { date: "Aug 2025", description: "Assembly Applications", completed: true, start: "2025-08-01", end: "2025-08-31" },
      { date: "Sep 2025", description: "W3C Collaboration<br/>Assembly Starts", completed: true, start: "2025-09-01", end: "2025-09-30" },
      { date: "Nov 2025", description: "Assembly Consensus<br/>Design Document", completed: true, start: "2025-11-01", end: "2025-11-30" },
      { date: "Q1 2026", description: "Specification Development", current: true, start: "2026-01-01", end: "2026-03-31" },
      { date: "2026", description: "Draft for Review", start: "2026-04-01", end: "2026-12-31" },
    ]}
  />

  <!-- Team (driven from projects.json) -->
  <TeamGrid
    heading="Project *Leadership*"
    body={parentWg ? `Part of the ${parentWg.name}` : ""}
    columns={sciWebProject?.leads?.length === 2 ? 2 : 3}
    highlighted={[]}
    members={(sciWebProject?.leads ?? []).map(lead => ({
      fullName: lead.fullName,
      role: lead.roleLabel,
    }))}
    bgClass="bg-white"
  />

  <!-- Get Involved -->
  <CardGrid
    heading="Get Involved"
    body="Help Shape Web Sustainability Measurement"
    columns={4}
    cards={[
      {
        icon: "/assets/standards/sci/resource-spec-icon.svg",
        title: "Read the Design Document",
        description: "Explore the consensus positions on scope, personas, and evaluation criteria",
        ctaText: "Read Document",
        ctaHref: "/policy/research/sci-web-assembly-report/",
        featured: true,
      },
      {
        icon: "/assets/standards/sci/resource-discuss-icon.svg",
        title: "Join the Software Standards Working Group",
        description: "Collaborate with industry experts shaping this specification (members only)",
        ctaText: "Join the WG",
        ctaHref: "https://directory.greensoftware.foundation/working-groups/software-standards-working-group/",
      },
      {
        icon: "/assets/standards/sci/resource-guide-icon.svg",
        title: "Visit the Directory",
        description: "Get in touch with the project lead and team",
        ctaText: "Learn more",
        ctaHref: "https://directory.greensoftware.foundation/projects/software-carbon-intensity-for-web-(sci-for-web)/",
      },
      {
        icon: "/assets/standards/soft/join-gsf-icon.svg",
        title: "Become a GSF Member",
        description: "Join the foundation to participate in standards development",
        ctaText: "Get in touch",
        ctaHref: "https://greensoftware.foundation/membership",
      },
    ]}
    bgClass="bg-accent-lightest-2"
  />

  <!-- Articles & Reports -->
  <ArticleCarousel
    heading="Featured Articles"
    body="Reports, announcements, and insights from the SCI for Web journey."
    showOrganizations={false}
    articles={carouselArticles}
    bgClass="bg-accent-lighter/10"
  />

  <!-- CTA -->
  <CTABanner
    heading="Shape the standards that define sustainable software"
    body="Our standards are developed by members working together. Join the Green Software Foundation to contribute to specifications, vote on decisions, and help set the direction for sustainable software worldwide."
    ctaText="Get a seat at the table"
    ctaHref="/membership/"
  />

  <Footer />
</Layout>
