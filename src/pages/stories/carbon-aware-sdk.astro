---
import { getCollection } from "astro:content";
import Layout from "@/layouts/showcase.astro";
import Navbar from "@/components/navbar.astro";
import Footer from "@/components/footer.astro";
import CTABanner from "@/components/cta-banner.astro";
import ArticleCarousel from "@/components/article-carousel.astro";
import { Card } from "@/components/ui/card";
import { navItems } from "@/lib/nav-items";
import logos from "@/data/logos.json";

const title = "We can't shift workloads to clean energy";
const summary = "How Microsoft, UBS, Avanade, NTT DATA, and partners built the Carbon Aware SDK — the first open-source toolkit for carbon-aware computing, now deployed on production banking systems and graduated from the Green Software Foundation.";

// ── Related articles ─────────────────────────────────────────────────────────
const relatedSlugs = [
  "en/celebrating-the-graduation-of-the-carbon-aware-sdk",
  "en/carbonhack22-a-big-leap-in-carbon-aware-computing",
  "en/carbon-aware-computing-whitepaper-how-ubs-succeeded-in-measuring-and-reducing-car",
  "en/upgrading-to-net-8-inside-the-carbon-aware-sdk-v1-4",
  "en/making-decentralized-systems-more-sustainable-meet-mani-hagh-sefat-of-energy-web",
];
const logoMap = new Map((logos as any[]).map(l => [l.name.toLowerCase(), l.logo]));
const allArticles = await getCollection("articles");
const relatedArticles = relatedSlugs
  .map(slug => allArticles.find(a => a.id === slug))
  .filter(Boolean)
  .map(a => ({
    title: a!.data.title,
    description: a!.data.teaserText || a!.data.summary || "",
    imageSrc: a!.data.mainImage?.src || "/assets/hero-illustration.svg",
    href: `/articles/${a!.id}/`,
    cta: "Read the article →",
    organizations: (a!.data.organizations || []).map((name: string) => ({
      name,
      logoSrc: logoMap.get(name.toLowerCase()),
    })),
  }));

// ── Organisations with logos ────────────────────────────────────────────────
const orgs = [
  { name: "Microsoft",  logo: "/assets/logos/microsoft.svg" },
  { name: "UBS",        logo: "/assets/logos/ubs.png" },
  { name: "NTT DATA",   logo: "/assets/logos/ntt-data.png" },
  { name: "Energy Web", logo: "/assets/logos/energy-web.png" },
  { name: "Avanade",    logo: null },
];

// ── Impact stats ────────────────────────────────────────────────────────────
const stats = [
  { value: "13–24%",  label: "Carbon reductions demonstrated at CarbonHack22" },
  { value: "395",     label: "Participants at CarbonHack22 across 51 projects" },
  { value: "40",      label: "Programming languages supported via client library" },
  { value: "1st",     label: "GSF project to achieve Graduated status" },
];

// ── Timeline ────────────────────────────────────────────────────────────────
const timeline = [
  {
    date: "2021",
    heading: "The concept emerges",
    body: "Members of the GSF Open Source Working Group identified carbon-aware computing as a quick win. Vaughan Knight at Microsoft launched the Carbon Aware SDK — starting with command-line tooling and a .NET library.",
  },
  {
    date: "2021–2022",
    heading: "From library to enterprise API",
    body: "Early conversations revealed companies needed not just a library but a centralised web API. By mid-2022, the SDK had a hosted API and a client library available in 40 different programming languages.",
  },
  {
    date: "Oct–Nov 2022",
    heading: "CarbonHack22 accelerates adoption",
    body: "The GSF ran its first-ever hackathon, coinciding with COP27. 395 participants submitted 51 projects built on the SDK. First place, Lowcarb, achieved 13% carbon reductions in federated machine learning. Second place, Zeus, showed 24% reductions in deep neural network training. Prize money totalled USD 100,000.",
  },
  {
    date: "January 2023",
    heading: "UBS deploys on production banking systems",
    body: "UBS and Microsoft integrated the Carbon Aware SDK into UBS's Advanced Compute Quantum Analytics risk platform, using WattTime data to time-shift workloads. The first enterprise-scale deployment of carbon-aware computing on a production banking system.",
  },
  {
    date: "2023–2024",
    heading: "Broader adoption and maturation",
    body: "Vesta used the SDK to shift wind turbine simulations to cleaner windows. NTT DATA and NTT contributed the .NET 8 upgrade (v1.4), adding Prometheus and Grafana integration and Kubernetes-level carbon monitoring dashboards.",
  },
  {
    date: "April 2024",
    heading: "First GSF project to graduate",
    body: "The Carbon Aware SDK became the first software project in the Green Software Foundation's history to achieve Graduated status, meeting all acceptance criteria including public release, clear documentation, and evidence of usefulness.",
  },
  {
    date: "October 2024",
    heading: "Decentralised carbon-aware computing",
    body: "Energy Web delivered the world's first decentralised computation nomination system based on sustainability factors using the Carbon Aware SDK — extending carbon-aware computing into blockchain and Web3.",
  },
];

// ── Featured quote ───────────────────────────────────────────────────────────
const featuredQuote = {
  text: "Carbon aware software does more when energy is clean and less when it's dirty.",
  author: "Green Software Foundation",
};

// ── Who came together ────────────────────────────────────────────────────────
const contributors = [
  {
    name: "Vaughan Knight",
    role: "Principal Engineering Manager",
    org: "Microsoft",
    photo: null,
    contribution: "Launched and led the Carbon Aware SDK project from inception through graduation.",
  },
  {
    name: "Kin Chiu",
    role: "Executive Director and Sustainable Technology Lead",
    org: "UBS",
    photo: null,
    contribution: "Drove UBS's strategic cloud initiative and led the Sustainable Technology Guild that connected UBS to GSF.",
  },
  {
    name: "Paul McEwen",
    role: "Global Head of Technology Services",
    org: "UBS",
    photo: null,
    contribution: "Championed the first enterprise-scale carbon-aware computing deployment on a production banking platform.",
  },
  {
    name: "Chris Lloyd-Jones",
    role: "Head of Open Technologies",
    org: "Avanade",
    photo: null,
    contribution: "Contributed to SDK development and CarbonHack22 sponsorship.",
  },
  {
    name: "Mani Hagh Sefat",
    role: "CTO and Board Member",
    org: "Energy Web",
    photo: null,
    contribution: "Delivered the world's first decentralised carbon-aware computation nomination system.",
  },
  {
    name: "Elisabeth Brinton",
    role: "Corporate Vice President, Sustainability",
    org: "Microsoft",
    photo: null,
    contribution: "Executive sponsor connecting Microsoft's sustainability commitments to GSF collaboration.",
  },
  {
    name: "Takuya Iwatsuka",
    role: "Engineer",
    org: "NTT DATA",
    photo: null,
    contribution: "Led the .NET 8 upgrade for Carbon Aware SDK v1.4.",
  },
  {
    name: "Damien Roux",
    role: "Engineer",
    org: "NTT DATA",
    photo: null,
    contribution: "Contributed to the .NET 8 upgrade and ongoing Carbon Aware SDK maintenance.",
  },
  {
    name: "Yasumasa Suenaga",
    role: "Engineer",
    org: "NTT DATA",
    photo: null,
    contribution: "Contributed to the .NET 8 upgrade engineering work.",
  },
];

// ── Additional quotes ─────────────────────────────────────────────────────────
const quotes = [
  {
    text: "The way we design and build our applications has a direct relationship to how much carbon they emit. With a better understanding of the impact our application designs have on the environment, we can make choices which have a more positive impact on the planet.",
    author: "Paul McEwen",
    role: "Global Head of Technology Services, UBS",
  },
  {
    text: "Little awareness and slow adoption of greener software practices are the key obstacles that I see. It's human nature to take the path of least resistance, especially when it's hard to see and feel the immediate impact of your contributions.",
    author: "Kin Chiu",
    role: "Executive Director and Sustainable Technology Lead, UBS",
  },
  {
    text: "At Microsoft, we are committed to helping organizations reach their sustainability goals. Carbon-aware computing advances the measurement and reduction of carbon emissions associated with software technology at a global scale.",
    author: "Elisabeth Brinton",
    role: "Corporate Vice President, Sustainability, Microsoft",
  },
];

function initials(name: string) {
  return name.split(" ").map(w => w[0]).join("").slice(0, 2).toUpperCase();
}
---

<Layout title={`${title} — GSF Member Story`} description={summary}>
  <Navbar
    navItems={navItems}
    logoSrc="/assets/gsf-logo-full.svg"
    logoAlt="Green Software Foundation"
    logoHref="/"
    topBar="none"
    showSearch
    ctaText="Discuss your challenges"
    ctaHref="/membership/"
  />

  <!-- ── Hero / header ─────────────────────────────────────────────────────── -->
  <div class="bg-primary-darker text-white">
    <div class="container pt-10 pb-16 md:pt-14 md:pb-20">
      <div class="max-w-4xl mx-auto">

        <!-- Breadcrumb — same pattern as article pages -->
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex items-center gap-2 text-sm text-white/60">
            <li>
              <a href="/" class="hover:text-white transition-colors flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
                Home
              </a>
            </li>
            <li class="text-white/30">/</li>
            <li><a href="/stories/" class="hover:text-white transition-colors">Stories</a></li>
            <li class="text-white/30">/</li>
            <li class="text-white/80 truncate max-w-[300px]">Carbon Aware SDK</li>
          </ol>
        </nav>

        <!-- Label + title -->
        <p class="text-accent font-bold text-sm uppercase tracking-widest mb-4">Member Story</p>
        <h1 class="font-extrabold text-4xl md:text-5xl lg:text-6xl leading-tight mb-6">
          "{title}"
        </h1>
        <p class="text-lg md:text-xl text-white/80 leading-relaxed max-w-3xl">
          {summary}
        </p>
      </div>
    </div>
  </div>

  <!-- ── Org logos ─────────────────────────────────────────────────────────── -->
  <div class="bg-white border-b border-border">
    <div class="container py-10 md:py-12">
      <div class="max-w-4xl mx-auto">
        <p class="text-gray-darker text-xs uppercase tracking-wider font-semibold mb-6 text-center">Organisations involved</p>
        <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6">
          {orgs.map(org => (
            org.logo ? (
              <img
                src={org.logo}
                alt={org.name}
                style="height: 32px; width: auto; max-width: 130px; object-fit: contain;"
              />
            ) : (
              <span class="text-primary-dark font-bold text-sm">{org.name}</span>
            )
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- ── Impact stats ─────────────────────────────────────────────────────── -->
  <div class="bg-accent-lightest-2 border-b border-border">
    <div class="container py-16 md:py-20">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
          {stats.map(stat => (
            <div class="text-center">
              <p class="font-extrabold text-4xl md:text-5xl text-primary mb-2">{stat.value}</p>
              <p class="text-sm text-gray-darker leading-snug">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- ── The Problem ──────────────────────────────────────────────────────── -->
  <div class="bg-white">
    <div class="container py-16 md:py-20">
      <div class="max-w-3xl mx-auto">
        <p class="text-accent font-bold text-sm uppercase tracking-widest mb-4">The Problem</p>
        <h2 class="font-extrabold text-3xl md:text-4xl text-primary mb-8 leading-tight">
          The grid was cleaner at certain times — but software had no way to know
        </h2>
        <div class="prose prose-lg max-w-none">
          <p>
            In 2021, organisations across the Green Software Foundation knew something frustrating: the electricity grid was cleaner at certain times and in certain places, but their software had no way to respond to that signal. Workloads ran on dirty power even when clean power was available hours later or in a neighbouring region.
          </p>
          <p>
            Every organisation faced the same fragmented landscape. Carbon data came from different providers — WattTime, Electricity Maps — in different formats, with different access methods. Building a carbon-aware application meant each company reinventing the same integration work.
          </p>
          <p>
            The need was clear: a shared, open-source toolkit that could centralise the logic, provide a common interface to multiple carbon data sources, and make it easy for any developer to build software that does more when the electricity is clean and less when it is dirty.
          </p>
        </div>

        <blockquote class="mt-10 border-l-4 border-accent pl-6 not-prose">
          <p class="text-xl font-semibold text-primary-dark italic leading-relaxed">
            "Little awareness and slow adoption of greener software practices are the key obstacles that I see. It's human nature to take the path of least resistance, especially when it's hard to see and feel the immediate impact of your contributions."
          </p>
          <footer class="mt-3 text-sm text-gray-darker">
            Kin Chiu — Executive Director and Sustainable Technology Lead, UBS
          </footer>
        </blockquote>
      </div>
    </div>
  </div>

  <!-- ── The Journey ──────────────────────────────────────────────────────── -->
  <div class="bg-accent-lightest-2">
    <div class="container py-16 md:py-20">
      <div class="max-w-3xl mx-auto">
        <p class="text-accent font-bold text-sm uppercase tracking-widest mb-4">The Journey</p>
        <h2 class="font-extrabold text-3xl md:text-4xl text-primary mb-16 leading-tight">
          From concept to the first graduated GSF project
        </h2>

        <div class="relative">
          <!-- Vertical line — left-3 (12px) = centre of w-6 (24px) dot -->
          <div class="absolute left-3 top-3 bottom-3 w-px bg-primary-lighter"></div>

          <div class="space-y-16">
            {timeline.map(entry => (
              <div class="relative flex gap-8">
                <div class="relative z-10 flex-none pt-1">
                  <div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center ring-4 ring-accent-lightest-2">
                    <div class="w-2 h-2 rounded-full bg-accent"></div>
                  </div>
                </div>
                <div class="flex-1 pb-2">
                  <h3 class="font-bold text-xl text-primary mb-1 leading-snug">{entry.heading}</h3>
                  <p class="text-accent font-extrabold text-xs uppercase tracking-widest mb-1">{entry.date}</p>
                  <p class="text-gray-darker leading-relaxed mb-3">{entry.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Featured quote ───────────────────────────────────────────────────── -->
  <div class="bg-primary text-white">
    <div class="container py-16 md:py-20">
      <div class="max-w-3xl mx-auto text-center">
        <svg class="w-10 h-10 text-accent mx-auto mb-6 opacity-60" fill="currentColor" viewBox="0 0 32 32">
          <path d="M10 8C6.686 8 4 10.686 4 14v10h10V14H7.333C7.333 11.791 8.791 10 10 10V8zm16 0c-3.314 0-6 2.686-6 6v10h10V14h-6.667C23.333 11.791 24.791 10 26 10V8z"/>
        </svg>
        <p class="font-extrabold text-3xl md:text-4xl leading-tight mb-6">
          {featuredQuote.text}
        </p>
        <p class="text-white/70 font-semibold">{featuredQuote.author}</p>
      </div>
    </div>
  </div>

  <!-- ── Who came together ─────────────────────────────────────────────────── -->
  <div class="bg-white">
    <div class="container py-16 md:py-20">
      <div class="max-w-4xl mx-auto">
        <p class="text-accent font-bold text-sm uppercase tracking-widest mb-4">Who came together</p>
        <h2 class="font-extrabold text-3xl md:text-4xl text-primary leading-tight">
          The people who made it happen
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-16">
          {contributors.map(person => (
            <Card className="flex flex-col items-center p-6 text-center h-full">
              <div class="mb-4 flex w-20 h-20 items-center justify-center overflow-hidden rounded-full bg-primary-lightest-2 shrink-0">
                {person.photo ? (
                  <img src={person.photo} alt={person.name} class="w-full h-full object-cover" />
                ) : (
                  <span class="text-xl font-bold text-primary/40">{initials(person.name)}</span>
                )}
              </div>
              <p class="font-bold text-base text-primary-dark">{person.name}</p>
              <p class="text-sm text-gray-darker mt-1">{person.role}</p>
              <p class="text-xs text-primary font-semibold mt-0.5">{person.org}</p>
              <p class="text-sm text-gray-darker mt-4 leading-relaxed border-t border-border pt-4 w-full">{person.contribution}</p>
            </Card>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- ── In their words ────────────────────────────────────────────────────── -->
  <div class="bg-accent-lightest-2">
    <div class="container py-16 md:py-20">
      <div class="max-w-4xl mx-auto">
        <p class="text-accent font-bold text-sm uppercase tracking-widest mb-10 text-center">In their words</p>
        <div class="grid md:grid-cols-3 gap-6">
          {quotes.map(q => (
            <div class="bg-white rounded-xl p-6 border border-border flex flex-col">
              <p class="text-gray-darker leading-relaxed flex-1 italic">"{q.text}"</p>
              <div class="mt-5 pt-5 border-t border-border">
                <p class="font-bold text-primary-dark text-sm">{q.author}</p>
                <p class="text-gray-darker text-xs mt-0.5">{q.role}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- ── Related articles ──────────────────────────────────────────────────── -->
  <ArticleCarousel
    heading="Related articles"
    body="Explore the stories behind the Carbon Aware SDK, from its first hackathon to enterprise deployment."
    articles={relatedArticles}
    bgClass="bg-white"
    showOrganizations={false}
  />

  <CTABanner
    heading="Be part of the next story"
    body="The Carbon Aware SDK was built by organisations who came together through the Green Software Foundation. Join us to collaborate on the standards, tools, and training that reduce software's environmental impact."
    ctaText="Discuss your challenges with us"
    ctaHref="/membership/"
    note="Already using the Carbon Aware SDK? Start with the quickstart guide at carbon-aware-sdk.greensoftware.foundation"
  />

  <Footer />
</Layout>
